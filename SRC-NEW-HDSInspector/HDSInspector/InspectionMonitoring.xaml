<UserControl x:Class="HDSInspector.InspectionMonitoring"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:my="clr-namespace:HDSInspector"
        xmlns:sub="clr-namespace:HDSInspector.SubControl"
        xmlns:igs="clr-namespace:IGS;assembly=IGS_Client"
        xmlns:igsSub="clr-namespace:IGS.SubControl;assembly=IGS_Client"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:common="clr-namespace:Common.Control;assembly=Common.Control"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:system="system"
        mc:Ignorable="d" 
        d:DesignHeight="970" d:DesignWidth="1900">
    <Grid Background="White" Name="grdMain">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="2"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1" Grid.Column="0" x:Name="GridInsResult" Grid.RowSpan="2" Grid.ColumnSpan="2" Background="Transparent">
        </Grid>
        <Grid Grid.Row="1" Grid.Column="2" x:Name="GridInsTypeUI1" Grid.ColumnSpan="3" Background="Transparent">
        </Grid>
        <Grid Grid.Row="2" Grid.Column="2" x:Name="GridInsTypeUI2" Grid.ColumnSpan="3" Background="Transparent">
        </Grid>
        <Grid  Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>

                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="120"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="5" Grid.RowSpan="2" Name="grd2D">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border  BorderThickness="1" CornerRadius="5,5,5,5" BorderBrush="LightGray" Background="WhiteSmoke" />
                <Button  x:Name="btnRead2D"  Style="{StaticResource SimpleButton}" Content="2D Mark" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

                <Border Grid.Row="1" Grid.RowSpan="7" Grid.ColumnSpan="2" Background="#FFF6EEEE" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
                <Label  x:Name="lbl2D" Content="인 식 결 과" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1,23,1,0" Foreground="Black" Height="24" Grid.RowSpan="3" VerticalAlignment="Top"/>

                <Border Grid.Row="2" Grid.Column="2" Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="2"></Border>
                <sub:ID_Reader x:Name="reader2D" Grid.Row="2" Margin="3"/>

            </Grid>
            <Grid Grid.Column="2" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#FF6E6E6E" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
                <Border Grid.Row="1" Grid.RowSpan="7" Grid.ColumnSpan="2" Background="#FFF6EEEE" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
                <Label Grid.Column="0" Grid.ColumnSpan="2" Content="Align 결과" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1" Foreground="White"/>
                <Label Grid.Column="0" Grid.Row="1" Content="X" FontSize="8"  Margin="0,-3" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="4" Content="X" FontSize="8"  Margin="0,-3" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="2" Content="Y" FontSize="8"  Margin="0,-3" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"  FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="5" Content="Y" FontSize="8"  Margin="0,-3" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"  FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="3" Content="Match" FontSize="8"  Margin="0,-3" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center"  FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="6" Content="Match" FontSize="8"  Margin="0, -3" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"   FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="7" Content="Angle" HorizontalAlignment="Center" VerticalContentAlignment="Top" FontSize="8"  Margin="0,-3" VerticalAlignment="Top"  FontWeight="Bold"/>
                <Label Name="lblX2" Grid.Column="1" Grid.Row="1" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblX1" Grid.Column="1" Grid.Row="4" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblY2" Grid.Column="1" Grid.Row="2" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblY1" Grid.Column="1" Grid.Row="5" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblM1" Grid.Column="1" Grid.Row="3" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblM2" Grid.Column="1" Grid.Row="6" Content="0" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
                <Label Name="lblAngle" Grid.Column="1" Grid.Row="7" Grid.ColumnSpan="1" Content="00.00" HorizontalAlignment="Center" FontSize="8" Margin="0,-3"/>
            </Grid>
            <Border Grid.Column="0" Background="#FF6E6E6E" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
            <Border Grid.Column="1" Background="#FF6E6E6E" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />

            <Label Grid.Column="0" Content="좌측 영상" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1,-6" Foreground="White"/>
            <Label Grid.Column="1" Content="우측 영상" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1,-6" Foreground="White"/>


            <Border Grid.Row="1" Grid.Column="0" Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="2"></Border>
            <Border Grid.Row="1" Grid.Column="1" Margin="1" Background="White" BorderBrush="LightGray" BorderThickness="2"></Border>

            <Image Name="imgAlign2" Grid.Row="1" Grid.Column="0" Margin="3"/>
            <Image Name="imgAlign1" Grid.Row="1" Grid.Column="1" Margin="3"/>

            <Grid Grid.Column="3" Grid.RowSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Grid.Column="0" Grid.ColumnSpan="2" Background="#FF6E6E6E" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
                <Border Grid.Row="1" Grid.RowSpan="5" Grid.ColumnSpan="2" Background="#FFF6EEEE" BorderThickness="2" CornerRadius="5,5,5,5" BorderBrush="LightGray" />
                <Label Grid.Column="0" Grid.ColumnSpan="2" Content="현재 Strip ID" FontSize="10" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1" Foreground="White"/>
                <Label Grid.Column="0" Grid.Row="1" Content="BA" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="11"  Margin="1" FontFamily="맑은고딕" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="2" Content="CA" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="11"  Margin="1" FontFamily="맑은고딕" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="3" Content="언로더" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="9"  Margin="1" FontFamily="맑은고딕" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="4" Content="마킹1" HorizontalContentAlignment="Center" HorizontalAlignment="Stretch" FontSize="11"  Margin="1" FontFamily="맑은고딕" FontWeight="Bold"/>
                <Label Grid.Column="0" Grid.Row="5" Content="마킹2" HorizontalAlignment="Center" VerticalContentAlignment="Top" FontSize="11"  Margin="1" VerticalAlignment="Top" FontFamily="맑은고딕" FontWeight="Bold"/>
                <Label Name="lblBotID" Grid.Column="1" Grid.Row="1" Content="0" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" FontFamily="굴림"  Margin="0,-2"/>
                <Label Name="lblTopID" Grid.Column="1" Grid.Row="2" Content="0" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" FontFamily="굴림"  Margin="0,-2"/>
                <Grid Grid.Row="3" Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Name="lblResID" Content="000" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0" FontFamily="굴림" FontWeight="Bold" FontSize="13"/>
                    <Label Grid.Column="1" Name="lblResult" Content="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="0" FontFamily="굴림" FontWeight="Bold" FontSize="13"/>
                </Grid>
                <Label Name="lblMk1ID" Grid.Column="1" Grid.Row="4" Content="0" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" FontFamily="굴림"  Margin="0,-2"/>
                <Label Name="lblMk2ID" Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="1" Content="0" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" FontFamily="굴림"  Margin="0,-2"/>
            </Grid>
            <Grid Grid.Column="4" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="0" Grid.ColumnSpan="4" Margin="1"/>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="1" Grid.ColumnSpan="4" Margin="1"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="0" Content="PLC" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" FontFamily="굴림" VerticalAlignment="Center"/>
                <Label Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" Content="Laser" HorizontalAlignment="Center" FontSize="13" FontWeight="Bold" FontFamily="굴림" VerticalAlignment="Center" />
                <my:LedLamp x:Name="lampPLC" Grid.Row="0" Grid.Column="0" Width="20" Height="18"></my:LedLamp>
                <my:LedLamp x:Name="lampMark" Grid.Row="1" Grid.Column="0" Width="20" Height="18"></my:LedLamp>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="2" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="1" Grid.Row="2" Content="V11" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV11" Grid.Row="2" Grid.Column="0" Width="20" Height="18"></my:LedLamp>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="3" Grid.Row="2" Content="V12" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV12" Grid.Row="2" Grid.Column="2" Width="20" Height="18"></my:LedLamp>

                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="3" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="1" Grid.Row="3" Content="V21" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV21" Grid.Row="3" Grid.Column="0" Width="20" Height="18"></my:LedLamp>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="3" Grid.Row="3" Content="V22" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV22" Grid.Row="3" Grid.Column="2" Width="20" Height="18"></my:LedLamp>

                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="4" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="1" Grid.Row="4" Content="V31" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV31" Grid.Row="4" Grid.Column="0" Width="20" Height="18"></my:LedLamp>
                <Border BorderBrush="LightGray" BorderThickness="2" CornerRadius="5" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="1"/>
                <Label Grid.Column="3" Grid.Row="4" Content="V32" Margin="-8,0,0,0" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"  VerticalAlignment="Center"/>
                <my:LedLamp x:Name="lampV32" Grid.Row="4" Grid.Column="2" Width="20" Height="18"></my:LedLamp>

            </Grid>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="490"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">마</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">킹</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">전</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">단</TextBlock>
            </Grid>

            <Grid Grid.Column="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">마</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">킹</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">후</TextBlock>
                <TextBlock FontSize="15" FontWeight="Bold" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">단</TextBlock>
            </Grid>

            <Border BorderBrush="DarkGray" BorderThickness="2" CornerRadius="6" Grid.Column="0" Margin="1"/>
            <Border BorderBrush="DarkGray" BorderThickness="2" CornerRadius="6" Grid.Column="2" Margin="1"/>

            <my:MarkMap Grid.Column="1" x:Name="Mark1Map" Margin="3" Grid.RowSpan="2"/>
            <my:MarkMap Grid.Column="3" x:Name="Mark2Map" Margin="3" Grid.RowSpan="2"/>
            <Image Name="imgLaserUse" Grid.Column="3" Source="/HDSInspector;component/Images/Laser_USE.png" Stretch="Fill" Margin="10,5"></Image>

            <Grid Grid.Column="4" Margin="0,1">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" BorderThickness="0" Cursor="Hand" Background="RoyalBlue" Name="btnPOPMenu" Margin="0,0.5">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5,0,0,5"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Vertical">
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="P"/>
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="O"/>
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="P"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="1" BorderThickness="0" Cursor="Hand" Background="Gray" Name="btnIssue" Margin="0,0.5">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5,0,0,5"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Vertical">
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="특"/>
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="이"/>
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="사"/>
                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" Text="항"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Column="5" BorderThickness="1" BorderBrush="Silver"/>

            <Grid Grid.Column="5" Name="grdPOP" Margin="1" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <igs:ReportMenuCtrl Grid.Column="0" x:Name="ReportCtrl"/>
                <igs:UserCtrl Grid.Column="1" Margin="5" x:Name="userCtrl"/>

                <!--<Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Image Grid.Row="0" Grid.RowSpan="2" Source="/HDSInspector;component/Images/CI.png" Stretch="Uniform" Margin="10,0"/>
                </Grid>-->
            </Grid>

            <Grid Grid.Column="5" Name="grdWarning" Margin="1" Visibility="Hidden">
                <igsSub:POP_WARNING_Ctrl x:Name="igsWarning"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>