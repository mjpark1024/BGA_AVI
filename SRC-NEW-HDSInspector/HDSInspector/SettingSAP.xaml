<UserControl x:Class="HDSInspector.SettingSAP"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.8*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,-1,0"/>
                <Border Grid.Row="2" Grid.RowSpan="5" Background="#AADDDDDD" Margin="1, 0, 0, 1"/>
                <Border Grid.Row="1" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="결과 파일 설정" Margin="5,3,0,0" FontWeight="Bold" Foreground="Black" FontSize="14"/>
                </Border>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20, 0, 0, 0" Grid.Row="0" Text="저장 경로" />
                    <TextBlock FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20, 0, 0, 0" Grid.Row="1" Text="공정 코드" />
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Width="170" Height="25" FontSize="12" Name="txtSAPPath"/>
                    <TextBox Grid.Row="1" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Width="170" Height="25" FontSize="12" Name="txtProcessCode"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="0" Grid.Column="1" Margin="-2,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" BorderBrush="DarkGray" BorderThickness="1" Margin="1,0,0,0"/>
                <Border Grid.Row="2" Grid.RowSpan="5" Background="#AADDDDDD" Margin="1, 0, 0, 1"/>
                <Border Grid.Row="1" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="불량 코드 설정" Margin="15,3,0,0" FontWeight="Bold" Foreground="Black" FontSize="14"/>
                </Border>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25, 0, 0, 10" Text="코드 설정" />
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1" Margin="1,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.Column="1" Margin="1,2,1,0" Background="DarkGray"  BorderBrush="#FF919191" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="17"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NumberBorder"/>
                            <Border Grid.Column="1" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NameBorder"/>
                            <Border Grid.Column="2" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="CodeBorder"/>
                            <Border Grid.Column="1" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                            <Border Grid.Column="2" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                            <TextBlock Grid.Column="0" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >No.</TextBlock>
                            <TextBlock Grid.Column="1" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >불량 이름</TextBlock>
                            <TextBlock Grid.Column="2" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >코드</TextBlock>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" Name="svDefectCodeViewer"  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden" Margin="1,0,1,0">
                        <ListBox x:Name="lbDefectCodeList" IsSynchronizedWithCurrentItem="True" SelectionMode="Single">
                            <ListBox.Background>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.5">
                                    <GradientStop Color="#77444444" Offset="1"/>
                                    <GradientStop Color="White" Offset="0.3"/>
                                </LinearGradientBrush>
                            </ListBox.Background>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding ElementName=NumberBorder, Path=ActualWidth}"/>
                                            <ColumnDefinition Width="{Binding ElementName=NameBorder, Path=ActualWidth}"/>
                                            <ColumnDefinition Width="{Binding ElementName=CodeBorder, Path=ActualWidth}"/>
                                            <ColumnDefinition Width="17"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Path=Number}" TextAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Path=Name}" TextAlignment="Center"/>
                                        <TextBox Grid.Column="2" Text="{Binding Path=Code}" TextAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" BorderBrush="DarkGray" BorderThickness="1" Margin="0,0,-1,0"/>
                <Border Grid.Row="2" Grid.RowSpan="5" Background="#AADDDDDD" Margin="1, 0, 0, 1"/>
                <Border Grid.Row="1" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="" Margin="5,3,0,0" FontWeight="Bold" Foreground="Black" FontSize="14"/>
                </Border>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                    <TextBlock Grid.Row="1" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                    <TextBlock Grid.Row="2" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1" Margin="5,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Grid.Column="1" Margin="-2,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="4*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="2.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" BorderBrush="DarkGray" BorderThickness="1" Margin="1,0,0,0"/>
                <Border Grid.Row="2" Grid.RowSpan="5" Background="#AADDDDDD" Margin="1, 0, 0, 1"/>
                <Border Grid.Row="1" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="" Margin="15,3,0,0" FontWeight="Bold" Foreground="Black" FontSize="14"/>
                </Border>

                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                    <TextBlock Grid.Row="1" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text=""/>
                    <TextBlock Grid.Row="2" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                    <TextBlock Grid.Row="3" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0" Text="" />
                </Grid>

                <Grid Grid.Row="2" Grid.Column="1" Margin="5, 0, 0, 0">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
