<Window x:Class="HDSInspector.SubWindow.WarningDlg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HDSInspector.SubWindow"
        mc:Ignorable="d"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True" Topmost="True" 
        Height="200" Width="350" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight">
    <Border Background="Yellow" BorderThickness="3" CornerRadius="15" x:Name="back">
        <Border.Effect>
            <DropShadowEffect BlurRadius="5" Direction="-90" RenderingBias="Quality" ShadowDepth="1"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Margin="10" Text="경고" VerticalAlignment="Center" Foreground="Red" FontSize="40"/>
            </StackPanel>
            <TextBlock Margin="10" x:Name="tbMessage" Grid.Row="1" Text="Content" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Height="Auto" Width="Auto"/>
            <Button Margin="10" Grid.Row="2" HorizontalAlignment="Center" FontFamily="Arial" FontSize="25" Style="{StaticResource materialStyle}" Click="Button_Click">확인</Button>
        </Grid>
    </Border>
</Window>
