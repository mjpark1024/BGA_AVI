<Window x:Class="HDSInspector.SubWindow.RangeSettingWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:common="clr-namespace:Common;assembly=Common"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="{x:Null}"
        Height="600" Width="390">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0.7*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 0, 18" Background="LightGray" Height="2" Grid.ColumnSpan="5"/>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 20, 18" Background="Black"     Height="2"/>

        <Border Grid.Row="2" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="3" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="4" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="5" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="6" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="7" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />

        <Label Grid.Row="0" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17">Range 설정</Label>
        <Label Grid.Row="1" Grid.Column="1" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17">MIN</Label>
        <Label Grid.Row="1" Grid.Column="3" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17">MAX</Label>
        <Label Grid.Row="2" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">Vent Hole</Label>
        <Label Grid.Row="3" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">인식키 검사</Label>
        <Label Grid.Row="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">표면 검사</Label>
        <Label Grid.Row="5" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">PSR 검사</Label>
        <Label Grid.Row="6" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">리드 형상검사</Label>
        <Label Grid.Row="7" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">공간 형상검사</Label>

        <Label Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">Pixel</Label>
        <Label Grid.Row="3" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">Pixel</Label>
        <Label Grid.Row="4" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">Pixel</Label>
        <Label Grid.Row="5" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">Pixel</Label>
        <Label Grid.Row="6" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">%</Label>
        <Label Grid.Row="7" Grid.Column="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">%</Label>

        <common:NumberTextBox  Grid.Row="2" Grid.Column="1" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="min_vent"/>
        <common:NumberTextBox  Grid.Row="2" Grid.Column="3" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="max_vent" IsEnabled="False"/>

        <common:NumberTextBox  Grid.Row="3" Grid.Column="1" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="min_cross" IsEnabled="False"/>
        <common:NumberTextBox  Grid.Row="3" Grid.Column="3" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="max_cross"/>

        <common:NumberTextBox  Grid.Row="4" Grid.Column="1" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="min_surface" IsEnabled="False"/>
        <common:NumberTextBox  Grid.Row="4" Grid.Column="3" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="max_surface"/>

        <common:NumberTextBox  Grid.Row="5" Grid.Column="1" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="min_psr" IsEnabled="False"/>
        <common:NumberTextBox  Grid.Row="5" Grid.Column="3" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="max_psr"/>

        <common:NumberTextBox  Grid.Row="6" Grid.Column="1" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="min_lead" IsEnabled="False"/>
        <common:NumberTextBox  Grid.Row="6" Grid.Column="3" Height="30"  Round="0" VerticalContentAlignment="Center" Margin="4" x:Name="max_lead"/>

        <common:NumberTextBox  Grid.Row="7" Grid.Column="1" Height="30" Round="0" MinValue="0" MaxValue="100" VerticalContentAlignment="Center" Margin="4" x:Name="min_space" IsEnabled="False"/>
        <common:NumberTextBox  Grid.Row="7" Grid.Column="3" Height="30"  Round="0" MinValue="0" MaxValue="100" VerticalContentAlignment="Center" Margin="4" x:Name="max_space"/>

        <Border Grid.Row="8" Grid.ColumnSpan="5">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFF5B17D" Offset="0.250"/>
                    <GradientStop Color="#FFC45F19" Offset="0.750"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <StackPanel Grid.Row="8" Grid.ColumnSpan="6" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Name="btnSave" Height="35" Width="95" Margin="10, 0">저 장</Button>
            <Button Name="btnCancel"  Height="35" Width="95" Margin="10, 0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
