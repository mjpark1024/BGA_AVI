<Window x:Class="HDSInspector.SubWindow.OuterSectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:Common;assembly=Common"
        xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow" Icon="{x:Null}"
        Title="외곽 섹션 반복 설정" Height="380" Width="360">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <!--Top-->
        <Label Grid.Row="0" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17" FontWeight="Bold">외곽 섹션 반복 설정</Label>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 0, 15" Background="LightGray" Height="2"/>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 200, 15" Background="Black" Height="2"/>

        <StackPanel Grid.Row="1" Height="205">
            <!-- Block Setting -->
            <Grid x:Name="pnlBlockSetting" Height="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.75*"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.ColumnSpan="3" Opacity="0.25">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Grid.Row="1" Grid.ColumnSpan="3" Opacity="0.25">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Grid.Row="2" Grid.ColumnSpan="3" Opacity="0.25">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Grid.Row="0" Margin="5, 0, 0, 0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold">Block 가로축 Gap (mm)</TextBlock>
                <common:NumberTextBox Grid.Row="0" Grid.Column="1" Margin="2" Name="txtBlockGap"
                                      FontSize="14" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                      Round="4" MinValue="0" MaxValue="10000">1234.5678</common:NumberTextBox>
                <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="DarkGray" Margin="0, 0, 5, 0" Name="lblBlockGap">123.456</TextBlock>
            </Grid>
            <!-- Unit Setting -->
            <Grid x:Name="pnlUnitSetting" Height="60">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.75*"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.ColumnSpan="3" Opacity="0.25">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border Grid.Row="1" Grid.ColumnSpan="3" Opacity="0.25">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Grid.Row="0" Margin="5, 0, 0, 0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold">Unit 가로 축 Pitch (mm)</TextBlock>
                <common:NumberTextBox Grid.Row="0" Grid.Column="1" Margin="2" Name="txtUnitXPitch"
                                      FontSize="14" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                      Round="4" MinValue="0" MaxValue="10000">1234.5678</common:NumberTextBox>
                <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="DarkGray" Margin="0, 0, 5, 0" Name="lblUnitPitchX">123.456</TextBlock>

                <TextBlock Grid.Row="1" Margin="5, 0, 0, 0" VerticalAlignment="Center" FontSize="13" FontWeight="Bold">Unit 세로 축 Pitch (mm)</TextBlock>
                <common:NumberTextBox Grid.Row="1" Grid.Column="1" Margin="2" Name="txtUnitYPitch"
                                      FontSize="14" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                      Round="4" MinValue="0" MaxValue="10000">1234.5678</common:NumberTextBox>
                <TextBlock Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="DarkGray" Margin="0, 0, 5, 0" Name="lblUnitPitchY">123.456</TextBlock>
            </Grid>

            <Border BorderBrush="#FF919191" BorderThickness="1" Height="20">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="12" FontFamily="Arial" FontWeight="Bold" Width="80" VerticalAlignment="Center" Margin="10, 0, 0, 0">반복 형태</TextBlock>
                </StackPanel>
            </Border>
            <Border Height="40" Background="Gray">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Margin="15,10" FontSize="15" x:Name="rbNone" IsChecked="true">반복 없음</RadioButton>
                    <RadioButton Margin="15,10" FontSize="15" x:Name="rbColumn">가로 반복</RadioButton>
                    <RadioButton Margin="15,10" FontSize="15" x:Name="rbRow">세로 반복</RadioButton>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" VerticalAlignment="Center" Visibility="Hidden" x:Name="pnlExclamation" Height="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image Source="/HDSInspector;component/Images/exclamation.png" Grid.Column="0" Margin="6"/>
            <TextBlock Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center" x:Name="txtWarnMessage" Foreground="Blue"/>
        </Grid>

        <Grid Grid.Row="4" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Width="100" Height="30" Name="btnOK">확 인</Button>
            <Button Width="100" Height="30" Grid.Column="1" Name="btnCancel">취 소</Button>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>
    </Grid>
</Window>
