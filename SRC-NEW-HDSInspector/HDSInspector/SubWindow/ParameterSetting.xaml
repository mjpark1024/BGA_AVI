<Window x:Class="HDSInspector.SubWindow.ParameterSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HDSInspector.SubWindow"
         xmlns:common="clr-namespace:Common;assembly=Common"
        mc:Ignorable="d"
        Title="ParameterSetting" Height="400" Width="320">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            <Border.Background>
                <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                    <GradientStop Color="#FF919191" Offset="1" />
                    <GradientStop Color="White" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Label Grid.Row="0" Grid.Column="0" Content="항목" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="0" Grid.Column="1" Content="Min" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="0" Grid.Column="2" Content="Max" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Vent Hole" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="2" Grid.Column="0" Content="Vent Hole2" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="3" Grid.Column="0" Content="인식키 검사" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="4" Grid.Column="0" Content="표면 검사" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="5" Grid.Column="0" Content="PSR 검사" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="6" Grid.Column="0" Content="리드 형상 검사" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>
        <Label Grid.Row="7" Grid.Column="0" Content="공간 형상 검사" Height="30" HorizontalAlignment="Center" FontWeight="Bold"/>


        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinVent" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="200"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMaxVent" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinVent2" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="200"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMaxVent2" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinCross" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMaxCross" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="50"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinSurface" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMaxSurface" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="500"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinPSR"  Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="5" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMaxPSR" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="500"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >pixel</Label>
        </StackPanel>
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinLead" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >%</Label>
        </StackPanel>
        <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox MaxValue="100" x:Name="txtMaxLead" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="80"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >%</Label>
        </StackPanel>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
            <common:NumberTextBox x:Name="txtMinSpace" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="0"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >%</Label>
        </StackPanel>
        <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal">
            <common:NumberTextBox MaxValue="100" x:Name="txtMaxSpace" Width="60" Height="30" Margin="5,0,0,0" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="80"/>
            <Label  HorizontalAlignment="Left" VerticalContentAlignment="Center" >%</Label>
        </StackPanel>

        <Grid Grid.Row="8" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.01*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Button Grid.Column="0" Margin="10" Name="btnOK" Click="btnSave_Click">저 장</Button>
            <Button Grid.Column="1" Margin="10" Name="btnCancel" Click="btnCancel_Click" Grid.ColumnSpan="2">취 소</Button>
        </Grid>
    </Grid>
</Window>
