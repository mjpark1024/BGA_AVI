<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDSInspector" x:Class="HDSInspector.LotWindow"
        xmlns:igs="clr-namespace:IGS.SubControl;assembly=IGS_Client"
        Title="Lot 입력" Height="640" Width="1300"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="580"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Image Opacity="0.5" Source="/HDSInspector;component/Images/metalic.jpg" Stretch="Fill" Grid.RowSpan="2" Grid.ColumnSpan="2"/>
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="DarkGray" BorderThickness="0,0,1,0"/>
        
        <Grid Grid.Row="0" Grid.Column="0" x:Name="UpperGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="95"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition />
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="Lot No"/>
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="Operator"/>
            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="투입 수량"/>

            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="ITS No"/>
            <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="공정코드"/>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="제조주차"/>

            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                <TextBox Width="110" Height="30" Margin="10,0" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold" x:Name="txtLot" TextAlignment="Left" CharacterCasing="Upper"/>
                <ComboBox Width="80" Height="30" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold" x:Name="cbLotType"/>
            </StackPanel>

            <TextBox Grid.Row="1" Grid.Column="3" Width="110" Height="30" HorizontalAlignment="Left" Margin="10,0,0,0" x:Name="txtITSLot" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" TextAlignment="Left" CharacterCasing="Upper"/>

            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                <TextBox Width="110" Height="30" HorizontalAlignment="Left" Margin="10,0" x:Name="txtOperator" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" TextAlignment="Left" CharacterCasing="Upper"/>
                <TextBlock Name="tbOperName" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="1" Margin="10,0,0,0" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Left" Name="tbPreCnt"/>

            <TextBox Grid.Row="3" Grid.Column="3" Width="110" Height="30" HorizontalAlignment="Left" Margin="10,0,0,0" x:Name="txtCode" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" TextAlignment="Left" CharacterCasing="Upper"/>
            <TextBox Grid.Row="4" Grid.Column="3" Width="110" Height="30" HorizontalAlignment="Left" Margin="10,0,0,0" x:Name="txtWeek" FontSize="16" FontWeight="Bold" VerticalContentAlignment="Center" TextAlignment="Left" CharacterCasing="Upper" IsEnabled="False"/>

            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Name="spMESState">
                <TextBlock FontSize="11" FontWeight="Bold" Foreground="Crimson" Text="전산 : "/>
                <TextBlock FontSize="11" FontWeight="Bold" Foreground="Crimson" Name="tbOpState"/>
            </StackPanel>
            
            <TextBlock Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" x:Name="txtGageLabel" FontSize="11" Margin="10,0">
                <Run Text="디스크 사용량"/>
            </TextBlock>

            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Text="검사 옵션"/>
            <Grid Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid x:Name="CheckBoxInspContainer" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Grid.RowSpan="2">
                    
                </Grid>
                <CheckBox Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" VerticalContentAlignment="Center" x:Name="cbMarkEnable" Margin ="-10,0,0,0 " FontWeight="Bold" Content="Mark 사용" Foreground="Tomato" IsEnabled="False"/>
                <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" VerticalContentAlignment="Center" x:Name="chkVerify" Margin ="-5,0,0,0 " Content="VRS 사용"/>
                <CheckBox Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" VerticalContentAlignment="Center" x:Name="chkUseAI" Content="AI 사용"/>
                <CheckBox Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="3" VerticalAlignment="Center" VerticalContentAlignment="Center" x:Name="cbConBad" Content="누적 Unit 불량 100Strip 시 정지 사용"/>
            </Grid>

            <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="4">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <igs:POP_WARNING_Ctrl Grid.Row="0" x:Name="igsWarningInfo"/>
                <igs:POP_CHANGE_POINT_Ctrl Grid.Row="1" x:Name="igsChangeInfo"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="10"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="250"/>
                <RowDefinition Height="30"/>
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border Grid.Row="1" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="고정불량 설정" Margin="5,1,0,0" FontWeight="Bold" Foreground="Black" FontSize="15" VerticalAlignment="Center"/>
            </Border>

            <CheckBox Grid.Row="1" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" x:Name="chkStaticMark" Content="고정마킹 사용"/>
            <local:LaserSelector Grid.Row="2" Grid.Column="0" x:Name="map" Height="240" Width="590"/>

            <Border Grid.Row="3" CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="불량명 AutoNG 설정" Margin="5,1,0,0" FontWeight="Bold" Foreground="Black" FontSize="15" VerticalAlignment="Center"/>
            </Border>

            <Grid Grid.Row="4" Margin="0,0,0,5">

                <ScrollViewer x:Name="AutoNG_List" VerticalScrollBarVisibility="Auto" IsEnabled="True">

                    <ItemsControl x:Name="AutoNG_Control" ItemsSource="{Binding}" IsEnabled="False">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                Content="{Binding Name}"
                                IsChecked="{Binding IsChecked}"
                                IsEnabled="{Binding IsEnabled}"     
                                Margin="5"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>






