<Window x:Class="HDSInspector.SubWindow.AddModelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HDSInspector.SubWindow"
        mc:Ignorable="d"
        Title="모델 추가" Height="150" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="1" FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Center">모델명</Label>
        <Label Grid.Row="1" Grid.Column="1" FontSize="20" FontWeight="Bold" HorizontalContentAlignment="Center">모델코드</Label>
        <TextBox Name="txtModelName" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="2" FontSize="20" FontWeight="Bold"></TextBox>
        <TextBox Name="txtModelCode" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="2" FontSize="20" FontWeight="Bold"></TextBox>
        <Button Name="btnOK" Grid.Row="2" Grid.Column="1" Margin="3" FontSize="15">확 인</Button>
        <Button Name="btnCancel" Grid.Row="2" Grid.Column="3" Margin="3" FontSize="15">취 소</Button>
    </Grid>
</Window>
