<Window x:Class="HDSInspector.SubWindow.GoldenLoadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:common="clr-namespace:Common;assembly=Common"
        mc:Ignorable="d"
        Icon="/HDSInspector;component/Images/goldenModel.png"
        Title="Golden Model"
        Height="700" Width="957"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarWhite}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarWhite}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Window.Background>
        <RadialGradientBrush RadiusY="0.726" RadiusX="0.475" GradientOrigin="0.401,0.247" Center="0.347,0.121">
            <GradientStop Color="#FF9799A3" Offset="0.946"/>
            <GradientStop Color="#FFEBEBEB"/>
        </RadialGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!-- First Column -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="10"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <!-- Center Margin -->
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="4" Content="불러오기" Name="btnOK"     Margin="1,2,-20, 2" FontWeight="Bold"
                    BorderThickness="1" BorderBrush="#888888" Style="{DynamicResource SimpleButton}"/>
            <Button Grid.Column="6" Content="취   소"  Name="btnCancel" Margin="-20,2,1, 2" FontWeight="Bold"
                    BorderThickness="1" BorderBrush="#888888" Style="{DynamicResource SimpleButton}"/>
            <!-- No. | Group -->
            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0, 2, 0, 0" Orientation="Horizontal">
                <StackPanel.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </StackPanel.Effect>
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
                <TextBlock Text="No." Width="50" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Text="Group" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
            </StackPanel>
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="3" BorderBrush="#FF919191" BorderThickness="1" Margin="0, 2, 0, 0"></Border>

            <!-- listbox -->
            <ScrollViewer x:Name="svGroup" Background="White" Grid.Row="2" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
                <ScrollViewer.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </ScrollViewer.Effect>
                <ListBox x:Name="lbGroup" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Index}" Margin="15, 0, 0, 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Code}"  Margin="0, 0, 0, 0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Name}"  Margin="15, 0, 0, 0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- No. | Model -->
            <StackPanel Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="3" Margin="0, 2, 0, 0" Orientation="Horizontal">
                <StackPanel.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </StackPanel.Effect>
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
                <TextBlock Text="No." Width="50" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Text="Model" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
            </StackPanel>
            <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="4" Grid.ColumnSpan="3" BorderBrush="#FF919191" BorderThickness="1" Margin="0, 2, 0, 0"/>

            <!-- listbox -->
            <ScrollViewer x:Name="svModel" Background="White" Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
                <ScrollViewer.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </ScrollViewer.Effect>
                <ListBox x:Name="lbModel" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Index}" Margin="15, 0, 0, 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="15, 0, 0, 0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
            
            <Grid Grid.Row="4" Grid.ColumnSpan="7" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="23"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0, 2, 0, 0" Orientation="Horizontal">
                    <StackPanel.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                    </StackPanel.Effect>
                    <StackPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </StackPanel.Background>                    
                </StackPanel>
                <TextBlock Grid.Column="0" Text="Author" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Grid.Column="1" Text="Date" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Grid.Column="2" Text="Comment" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>

                <ScrollViewer x:Name="svHistory" Background="White" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
                    <ListBox x:Name="lbHistory" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True" >
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Author}" Margin="8, 0, 0, 0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat='yyyy-MM-dd HH:mm:ss'}" Margin="8, 0, 0, 0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Comment}" Margin="8, 0, 0, 0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="Transparent">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Name="txtNoResult" Margin="0,0,0,15"  FontFamily="Arial" FontSize="40" FontWeight="Bold" Foreground="DarkGray" VerticalAlignment="Center" HorizontalAlignment="Center">정보 없음</TextBlock>
                        <TextBlock Name="txtNoResultSub" Margin="0,0,0,20"  FontFamily="Arial" FontSize="16" FontWeight="Bold" Foreground="DarkGray" VerticalAlignment="Center" HorizontalAlignment="Center">장비 타입이 맞지 않아 티칭 데이터를 불러올 수 없습니다.</TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
        
        <!-- Model Specification -->
        <Grid Grid.Column="4" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.ColumnSpan="2">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtModelName" VerticalAlignment="Center" TextWrapping="Wrap" 
                        Foreground="White" FontSize="22" FontFamily="Arial" FontWeight="Bold" Margin="15, 0">선택된 모델이 없습니다.</TextBlock>
                </ScrollViewer>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#4c7eb6" Offset="0.250"/>
                        <GradientStop Color="#195aa2" Offset="0.750"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>


            <Grid Grid.Row="1"  Background="White" x:Name="pnlModelSpec">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="0.2*"/>
                    <ColumnDefinition Width="0.2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>

                <Label  Grid.Row="0" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">제품 길이</Label>
                <Label  Grid.Row="1" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">제품 폭</Label>
                <Label  Grid.Row="2" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">보정치</Label>
                <Label  Grid.Row="3" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Scan 속도</Label>
                <Label  Grid.Row="4" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">양품적재 수</Label>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="4" VerticalAlignment="Center" Orientation="Horizontal">                   
                    <Label FontSize="14" FontFamily="Arial" Foreground="White" FontWeight="Bold">Block 구분 정보</Label>
                    <StackPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#4c7eb6" Offset="0.250"/>
                            <GradientStop Color="#195aa2" Offset="0.750"/>
                        </LinearGradientBrush>
                    </StackPanel.Background>
                </StackPanel>

                <Label  Grid.Row="6" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Block X-Count</Label>
                <Label  Grid.Row="7" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Block Y-Count</Label>
                <Label  Grid.Row="8" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Block X-Gap</Label>
                <Label  Grid.Row="9" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Block Y-Gap</Label>

                <StackPanel Grid.Row="10" Grid.ColumnSpan="4" VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Label FontSize="14" FontFamily="Arial" Foreground="White" FontWeight="Bold">Unit 구분 정보</Label>
                    <StackPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#4c7eb6" Offset="0.250"/>
                            <GradientStop Color="#195aa2" Offset="0.750"/>
                        </LinearGradientBrush>
                    </StackPanel.Background>
                </StackPanel>

                <Label  Grid.Row="11" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Unit X-Count</Label>
                <Label  Grid.Row="12" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Unit Y-Count</Label>
                <Label  Grid.Row="13" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Unit X-Pitch</Label>
                <Label  Grid.Row="14" VerticalAlignment="Center" Margin="5, 0" FontSize="14" FontFamily="Arial">Unit Y-Pitch</Label>

                <Label  Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label  Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label  Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label  Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial" Grid.ColumnSpan="2">mm/sec</Label>
                <Label  Grid.Row="8" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label  Grid.Row="9" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label Grid.Row="13" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>
                <Label Grid.Row="14" Grid.Column="2" VerticalAlignment="Center" FontSize="14" FontFamily="Arial">mm</Label>

                <common:NumberTextBox IsReadOnly="True" Grid.Row="0" Grid.Column="1" MinValue="0.0" MaxValue="300.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Width}" x:Name="txtWidth"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="1" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Height}" x:Name="txtHeight"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="2" Grid.Column="1" MinValue="0.0" MaxValue="10000.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Align}" x:Name="txtAlign"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="3" Grid.Column="1" MinValue="0"   MaxValue="500"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding ScanVelocity}" x:Name="txtScanVelocity"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="4" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding LoadGoodCount}" x:Name="txtLoadGoodCount"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="6" Grid.Column="1" MinValue="1"   MaxValue="100"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockColumn}" x:Name="txtBlockX"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="7" Grid.Column="1" MinValue="1"   MaxValue="100"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockRow}" x:Name="txtBlockY"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="8" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockWidth}" x:Name="txtBlockPitchX"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="9" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockHeight}" x:Name="txtBlockPitchY"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="11" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitColumn}" x:Name="txtUnitX"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="12" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitRow}" x:Name="txtUnitY"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="13" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitWidth}" x:Name="txtUnitPitchX"/>
                <common:NumberTextBox IsReadOnly="True" Grid.Row="14" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitHeight}" x:Name="txtUnitPitchY"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
