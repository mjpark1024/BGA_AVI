<Window x:Class="HDSInspector.SubWindow.GoldenHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Golden Model History" Height="450" Width="430" WindowStyle="ToolWindow" Topmost="True" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="{x:Null}">
    <Grid Grid.Row="4" Grid.ColumnSpan="7" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1.6*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="23"/>
            <RowDefinition/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0, 2, 0, 0" Orientation="Horizontal">
            <StackPanel.Effect>
                <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
            </StackPanel.Effect>
            <StackPanel.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </StackPanel.Background>
        </StackPanel>
        <TextBlock Grid.Column="0" Text="Author" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
        <TextBlock Grid.Column="1" Text="Date" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
        <TextBlock Grid.Column="2" Text="Comment" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>

        <ScrollViewer x:Name="svHistory" Background="White" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
            <ListBox x:Name="lbHistory" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="3*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Author}" Margin="5, 0, 0, 0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat='yyyy-MM-dd HH:mm:ss'}" Margin="15, 0, 0, 0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Comment}" Margin="15, 0, 0, 0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"/>
        
        <Button Grid.Row="2" Grid.Column="2" Width="110" HorizontalAlignment="Right" Margin="3,7,3,3" Name="btnOK">확 인</Button>
    </Grid>
</Window>
