<Window x:Class="HDSInspector.SubWindow.FirstMarkSetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="마킹 시작 위치 설정" Height="220" Width="300" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" CornerRadius="0,0,0,0" Grid.Column="1" Margin="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="Position X" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
        </Border>
        <Border Grid.Row="0" CornerRadius="0,0,0,0" Grid.Column="2" Margin="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="Position Y" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
        </Border>
        <Border Grid.Row="1" CornerRadius="0,0,0,0" Margin="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="현재 위치" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
        </Border>
        <Border Grid.Row="2" CornerRadius="0,0,0,0" Margin="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="Offset" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
        </Border>
        <Border Grid.Row="3" CornerRadius="0,0,0,0" Margin="1,1,1,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF919191" Offset="1"/>
                    <GradientStop Color="White"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="적용 위치" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="Black" FontSize="14"/>
        </Border>
        <StackPanel Orientation="Horizontal"  VerticalAlignment="Center" Grid.Row="4" Grid.ColumnSpan="3" Margin="5">
            <Button Name="btnSave" Height="30" Width="95" Margin="45,0,5,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Source="../Images/save_file_128_128.png" Width="20" Height="20" Margin="-5, 0, 0, 0"/>
                    <TextBlock FontWeight="Normal" FontSize="12" Text="확 인" VerticalAlignment="Center" Margin="10, 0, 10, 0"/>
                </StackPanel>
            </Button>
            <Button Name="btnClose" Height="30" Width="95" Margin="5,0,10,0">취 소</Button>
        </StackPanel>
        <Label Grid.Column="1" Grid.Row="1" Margin="0" FontSize="15" Name="lblFMX">0.0000</Label>
        <Label Grid.Column="2" Grid.Row="1" Margin="0" FontSize="15" Name="lblFMY">0.0000</Label>
        <Label Grid.Column="1" Grid.Row="2" Margin="0" FontSize="15" Name="lblOSX">0.0000</Label>
        <Label Grid.Column="2" Grid.Row="2" Margin="0" FontSize="15" Name="lblOSY">0.0000</Label>
        <Label Grid.Column="1" Grid.Row="3" Margin="0" FontSize="15" Name="lblCMX">0.0000</Label>
        <Label Grid.Column="2" Grid.Row="3" Margin="0" FontSize="15" Name="lblCMY">0.0000</Label>
    </Grid>
</Window>
