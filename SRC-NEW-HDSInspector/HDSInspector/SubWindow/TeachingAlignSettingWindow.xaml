<Window x:Class="HDSInspector.TeachingAlignSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:Common;assembly=Common"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow" Icon="{x:Null}"
        Title="Align 설정" Height="210" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="25"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Margin="10, 0, 0, 0" VerticalAlignment="Center" FontSize="14">Margin X</TextBlock>
        <TextBlock Grid.Row="1" Margin="10, 0, 0, 0" VerticalAlignment="Center" FontSize="14">Margin Y</TextBlock>
        <TextBlock Grid.Row="2" Margin="10, 0, 0, 0" VerticalAlignment="Center" FontSize="14">일치율</TextBlock>
        
        <TextBlock Grid.Row="0" Grid.Column="2" Margin="2, 0, 0, 0" VerticalAlignment="Center" FontSize="14" Foreground="DarkGray">px</TextBlock>
        <TextBlock Grid.Row="1" Grid.Column="2" Margin="2, 0, 0, 0" VerticalAlignment="Center" FontSize="14" Foreground="DarkGray">px</TextBlock>
        <TextBlock Grid.Row="2" Grid.Column="2" Margin="2, 0, 0, 0" VerticalAlignment="Center" FontSize="14" Foreground="DarkGray">%</TextBlock>
        
        <common:NumberTextBox FontSize="14" VerticalContentAlignment="Center" Margin="2, 4"
                              MinValue="0" MaxValue="10000" Round="0" Name="txtAlignMarginX"
                              Grid.Row="0" Grid.Column="1">300</common:NumberTextBox>
        <common:NumberTextBox FontSize="14" VerticalContentAlignment="Center" Margin="2, 4"
                              MinValue="0" MaxValue="10000" Round="0" Name="txtAlignMarginY"
                              Grid.Row="1" Grid.Column="1">300</common:NumberTextBox>
        <common:NumberTextBox FontSize="14" VerticalContentAlignment="Center" Margin="2, 4"
                              MinValue="0" MaxValue="100" Round="0" Name="txtAlignAcceptance"
                              Grid.Row="2" Grid.Column="1">90</common:NumberTextBox>

        <Grid Grid.Row="4" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Width="100" Height="30" Name="btnOK">확 인</Button>
            <Button Width="100" Height="30" Grid.Column="1" Name="btnCancel">취 소</Button>
            <Grid.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>
    </Grid>
</Window>
