<Window x:Class="HDSInspector.SubWindow.QuestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키" Height="350" Width="400" WindowStyle="ToolWindow" Topmost="True" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="{x:Null}"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!--Top-->
        <Label Grid.Row="0" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17" FontWeight="Bold">단축키 모음</Label>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 0, 15" Background="LightGray" Height="2" Grid.ColumnSpan="4"/>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 15, 15" Background="Black"     Height="2"/>

        <!--Center 1-->
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Name="page1" Tag="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" HorizontalAlignment="Left" Margin="13, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="4" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="5" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="6" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="7" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="16" FontWeight="Bold">티칭 윈도우</TextBlock>
            <TextBlock Grid.Row="1" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F3]</TextBlock>
            <TextBlock Grid.Row="2" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F4]</TextBlock>
            <TextBlock Grid.Row="3" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F5]</TextBlock>
            <TextBlock Grid.Row="4" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F6]</TextBlock>
            <TextBlock Grid.Row="5" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F7]</TextBlock>
            <TextBlock Grid.Row="6" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[F8]</TextBlock>
            <TextBlock Grid.Row="7" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="15" FontWeight="Bold">[ESC]</TextBlock>

            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">전체영상 보기</TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">기준영상 보기</TextBlock>
            <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">영상 취득</TextBlock>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">비전 전송</TextBlock>
            <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">부분 검사</TextBlock>
            <TextBlock Grid.Row="6" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">전체 검사</TextBlock>
            <TextBlock Grid.Row="7" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">창 닫기</TextBlock>
        </Grid>

        <!--Center 2-->
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Name="page2" Tag="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" HorizontalAlignment="Left" Margin="13, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="4" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="5" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="6" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="7" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            
            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="16" FontWeight="Bold">티칭 뷰어</TextBlock>
            <TextBlock Grid.Row="1" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold" Grid.ColumnSpan="2">[Space + 마우스]</TextBlock>
            <TextBlock Grid.Row="2" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + C]</TextBlock>
            <TextBlock Grid.Row="3" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + V]</TextBlock>
            <TextBlock Grid.Row="4" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + Z]</TextBlock>
            <TextBlock Grid.Row="5" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + Y]</TextBlock>
            <TextBlock Grid.Row="6" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[방향키]</TextBlock>
            <TextBlock Grid.Row="7" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + 방향키]</TextBlock>

            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">화면 이동</TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">도형 복사</TextBlock>
            <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">도형 붙여넣기</TextBlock>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">Undo</TextBlock>
            <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">Redo</TextBlock>
            <TextBlock Grid.Row="6" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">도형 이동</TextBlock>
            <TextBlock Grid.Row="7" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">도형 미세 이동</TextBlock>

        </Grid>

        <!--Center 3-->
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Name="page3" Tag="3">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" HorizontalAlignment="Left" Margin="13, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
            <Border Grid.Row="3" HorizontalAlignment="Left" Margin="13, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="4" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.Row="5" Grid.ColumnSpan="3" Margin="0,0,0,0" Opacity="0.25">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
                        
            <TextBlock Grid.Row="0" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="16" FontWeight="Bold">임계치</TextBlock>
            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="14" FontWeight="Bold">[Box클릭 후 마우스 휠]</TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">임계값 조정</TextBlock>
            <TextBlock Grid.Row="3" VerticalAlignment="Center" Margin="20, 0, 0, 0" FontSize="16" FontWeight="Bold">조명</TextBlock>
            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="14" FontWeight="Bold">[Box클릭 후 마우스 휠]</TextBlock>
            <TextBlock Grid.Row="5" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="14" FontWeight="Bold">[Ctrl + Slide 드레그]</TextBlock>
            <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">조명값 조정</TextBlock>
            <TextBlock Grid.Row="5" Grid.Column="2" VerticalAlignment="Center" Margin="0, 0, 0, 0" FontSize="14">조명값 일괄 조정</TextBlock>
        </Grid>

        <!--Bottom-->
        <Border Grid.Row="7" Grid.ColumnSpan="4">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <StackPanel Grid.Row="7" Grid.ColumnSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Name="btnPrev" Height="35" Width="30" Margin="0,0,30,0" Style="{DynamicResource NullBackgroundButtonStyle}" Cursor="Hand">
                <Image Source="/HDSInspector;component/Images/whitePrev.png" Stretch="None"/>
            </Button>
            <TextBlock Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0" Name="txtCurrentPage">1 </TextBlock>
            <TextBlock Foreground="White" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"> / 3</TextBlock>
            <Button Name="btnNext"  Height="35" Width="30" Margin="30,0,0,0" Style="{DynamicResource NullBackgroundButtonStyle}" Cursor="Hand">
                <Image Source="/HDSInspector;component/Images/whiteNext.png" Stretch="None"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>

