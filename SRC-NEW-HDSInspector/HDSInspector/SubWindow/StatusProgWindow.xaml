<Window x:Class="HDSInspector.SubWindow.StatusProgWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StatusProgWindow" Height="200" Width="160" WindowStyle ="None" SizeToContent="Height"
        Topmost="True" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="canvasStyle" TargetType="{x:Type Canvas}">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style x:Key ="Ellipse"
                     TargetType="{x:Type Ellipse}">
            <Setter Property="Width" Value="15"/>
            <Setter Property="Height" Value="15"/>
            <Setter Property="Fill" Value="#898989"/>
            <Setter Property="Canvas.Left" Value="0"/>
            <Setter Property="Canvas.Top" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Label Grid.Row="1" Name="lblStatus" FontSize="15" HorizontalContentAlignment="Center" Foreground="Red" FontWeight="Bold">대기</Label>

        <Canvas RenderTransformOrigin="0.5,0.5" 
             Style="{StaticResource canvasStyle}" Grid.Row="0">
            <Canvas Name="rotationCanvas" 
               RenderTransformOrigin="0.5,0.5" 
               Style="{StaticResource canvasStyle}" Canvas.Left="25" Canvas.Top="94">
                <Ellipse Name="circle1" Style="{StaticResource Ellipse}" Opacity="0.3">
                </Ellipse>
                <Ellipse Opacity="0.3" 
                    Style="{StaticResource Ellipse}">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="30" 
                            CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                    Style="{StaticResource Ellipse}">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="60" 
                           CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                     Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="90" 
                          CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                   Style="{StaticResource Ellipse}">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="120" 
                         CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                      Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="150" 
                           CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                      Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="180" 
                          CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                    Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="210" 
                      CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.3" 
                      Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="240" 
                      CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.5" 
                  Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="270" 
                      CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.7"
                 Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="300" 
                      CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Opacity="0.8" 
                   Style="{StaticResource Ellipse}" >
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="330" 
                       CenterX="50" CenterY="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Canvas.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate"  
                   Angle="0" CenterX="50" 
                   CenterY="0" />
                </Canvas.RenderTransform>
            </Canvas>
        </Canvas>
    </Grid>
</Window>

