<Window x:Class="HDSInspector.SubWindow.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="{x:Null}"
        Height="400" Width="370">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.15*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="0.5*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 0, 18" Background="LightGray" Height="2" Grid.ColumnSpan="4"/>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 20, 18" Background="Black"     Height="2"/>

        <Border Grid.Row="1" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="2" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="3" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="4" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="5" HorizontalAlignment="Left" Margin="8, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />

        <Label Grid.Row="0" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17">사용자 등록</Label>
        <Label Grid.Row="1" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">ID</Label>
        <Label Grid.Row="2" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">이름</Label>
        <Label Grid.Row="3" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">비밀번호</Label>
        <Label Grid.Row="4" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">비밀번호 확인</Label>
        <Label Grid.Row="5" VerticalAlignment="Center" Margin="13, 0, 0, 0" FontSize="15">사용 권한</Label>

        <Image Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
               Source="/HDSInspector;component/Images/checked.png" Name="imgValidID"/>
        <TextBox Name="txtID"   
                 Grid.Row="1" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <Button Name="btnCheckID" Grid.Row="1" Grid.Column="3" Margin="5" FontSize="13">중복확인</Button>
        <TextBox Name="txtName" 
                 Grid.Row="2" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <PasswordBox Name="txtNewPassword" 
                 Grid.Row="3" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <PasswordBox Name="txtCheckNewPassword" 
                 Grid.Row="4" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <ComboBox Name="cmbAuthority" 
                 Grid.Row="5" Grid.Column="1" Margin="5" VerticalContentAlignment="Center"/>

        <Border Grid.Row="7" Grid.ColumnSpan="4">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <StackPanel Grid.Row="7" Grid.ColumnSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Name="btnOK" Height="35" Width="95" Margin="10, 0">확 인</Button>
            <Button Name="btnCancel"  Height="35" Width="95" Margin="10, 0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
