<Window x:Class="HDSInspector.SubWindow.SettingsXMLWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="자세히 보기" Height="500" Width="700" ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <ScrollViewer Name="NGContListScrollViewer" Grid.Row = "0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
            <TextBox Name="txtSettingsXML" TextAlignment="Left"/>
        </ScrollViewer>
        <Border Grid.Row ="1" Background ="LightGray"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Grid.Row="1">
            <Button Name="btnSave" Height="35" Width="95" Margin="5, 0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Source="../Images/save_file_128_128.png" Width="20" Height="20" Margin="-5, 0, 0, 0"/>
                    <TextBlock FontWeight="Normal" FontSize="12" Text="저 장" VerticalAlignment="Center" Margin="10, 0, 10, 0"/>
                </StackPanel>
            </Button>
            <Button Name="btnClose" Height="35" Width="95" Margin="5, 0">닫 기</Button>
        </StackPanel>
    </Grid>
</Window>
