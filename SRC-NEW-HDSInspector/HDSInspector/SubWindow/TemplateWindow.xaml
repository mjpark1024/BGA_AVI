<Window x:Class="HDSInspector.SubWindow.TemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="검사방법 Templete" Height="650" Width="600" xmlns:my="clr-namespace:HDSInspector" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <Style TargetType="{x:Type Label}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarWhite}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarWhite}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid Background="#D3D3D3" Margin="3" Name="grdName">
            <Grid.RowDefinitions>
                <RowDefinition Height="23"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                        <GradientStop Color="#4c7eb6" Offset="0.250"/>
                        <GradientStop Color="#195aa2" Offset="0.750"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Foreground="White" Margin="10, 0">검사 영역 리스트</TextBlock>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="txtName"/>
                <Button   Grid.Column="1" Style="{DynamicResource SimpleButton}" Name="btnAddName"
                      BorderBrush="#888888" BorderThickness="1, 0, 1, 0">추 가</Button>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FF919191" BorderThickness="1"
                    Grid.Row="0" Grid.ColumnSpan="1">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial"
                           Width="50" VerticalAlignment="Center" Margin="5, 0, 0, 0">번호</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" FontFamily="Arial"
                           VerticalAlignment="Center" Margin="20, 0, 0, 0">검사 영역</TextBlock>
                    </StackPanel>
                </Border>

                <ScrollViewer Name="svNameList" VerticalScrollBarVisibility="Visible" 
                          Grid.Row="1" Grid.ColumnSpan="1" HorizontalAlignment="Stretch" Background="White">
                    <ListBox SelectionMode="Single" Name="lbName" ItemsSource="{Binding}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Path=ID}" Width="50" Margin="5, 0, 0, 0" FontSize="11"/>
                                    <TextBlock Text="{Binding Path=Name}" Margin="20, 0, 0, 0" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
            <Grid Grid.Row="4" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Name="btnSelect" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">추 가</Button>
                <Button Grid.Column="1" Name="btnSaveAll" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 1, 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Image Source="/HDSInspector;component/Images/save_file_128_128.png" Width="20" Height="20" Margin="-2, 0, 0, 0"/>
                        <TextBlock FontWeight="Normal" Text="저 장" VerticalAlignment="Center" Margin="5, 0, 0, 0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Name="btnRename" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">변 경</Button>
                <Button Grid.Column="3" Name="btnDeleteName" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 0, 0">삭 제</Button>
            </Grid>
        </Grid>
        <Grid Grid.Column="1" Background="#D3D3D3" Margin="3" Name="grdInsepct">
            <Grid.RowDefinitions>
                <RowDefinition Height="23"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                        <GradientStop Color="#4c7eb6" Offset="0.250"/>
                        <GradientStop Color="#195aa2" Offset="0.750"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Foreground="White" Margin="10, 0 , 180, 0">검사 방법 리스트</TextBlock>
                
            </Border>
            <TextBlock Foreground="White" Margin="120, 0 , 10, 0" Name="tbName">[]</TextBlock>
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FF919191" BorderThickness="1"
                    Grid.Row="0" Grid.ColumnSpan="1">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial"
                           Width="50" VerticalAlignment="Center" Margin="5, 0, 0, 0">번호</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" FontFamily="Arial"
                           VerticalAlignment="Center" Margin="20, 0, 0, 0">검사 방법</TextBlock>
                    </StackPanel>
                </Border>

                <ScrollViewer Name="svInspectionList" VerticalScrollBarVisibility="Visible" 
                          Grid.Row="1" Grid.ColumnSpan="1" HorizontalAlignment="Stretch" Background="White">
                    <ListBox SelectionMode="Single" Name="lbInspection" ItemsSource="{Binding}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Path=ID}" Width="50" Margin="5, 0, 0, 0" FontSize="11"/>
                                    <TextBlock Text="{Binding Path=InspectionType.Name}" Margin="20, 0, 0, 0" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>

            <Grid Grid.ColumnSpan="3" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Style="{DynamicResource SimpleComboBox}" Name="cmbInspectionType"/>
                <Button   Grid.Column="1" Style="{DynamicResource SimpleButton}" Name="btnAddInspectionType"
                      BorderBrush="#888888" BorderThickness="1, 0, 1, 0">추 가</Button>
            </Grid>

            <Grid Grid.Row="3" Grid.Column="1" Name="pnlInspectionSettings" RenderTransformOrigin="0,0"
              Background="#D3D3D3">
            </Grid>

            <Grid Grid.Row="4" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Name="btnSave" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 1, 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Image Source="/HDSInspector;component/Images/save_file_128_128.png" Width="20" Height="20" Margin="-2, 0, 0, 0"/>
                        <TextBlock FontWeight="Normal" Text="적용" VerticalAlignment="Center" Margin="5, 0, 0, 0"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Name="btnSetPreview" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">직전값 복원</Button>
                <Button Grid.Column="3" Name="btnClose" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">취 소</Button>
                <Button Grid.Column="2" Name="btnDelete"     Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 0, 0">삭 제</Button>
            </Grid>
        </Grid>
        <Grid Grid.ColumnSpan="2" Margin="120,250" Name="grdInput" Background="White" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2" Background="Gray"></Border>
            <Label Grid.ColumnSpan="2" FontSize="15" Foreground="White">변경할 영역을 입력 하세요.</Label>
            <Label Grid.Row="1" FontSize="15" HorizontalAlignment="Left">영역 :</Label>
            <TextBox Name="txtRename" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="50,2,2,2"></TextBox>
            <Button Grid.Row="2" Grid.Column="0" Name="btnRenameOK" FontSize="15" Margin="20,2">확 인</Button>
            <Button Grid.Row="2" Grid.Column="1" Name="btnRenameCancel" FontSize="15" Margin="20,2">취 소</Button>
        </Grid>
    </Grid>
</Window>
