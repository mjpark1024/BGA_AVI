<Window xmlns:my="clr-namespace:Common.Control;assembly=Common.Control"  x:Class="HDSInspector.SubWindow.OfflineModelSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:common="clr-namespace:Common;assembly=Common"
        Title="오프라인 모델 선택" Height="600" Width="900"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarWhite}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarWhite}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Window.Background>
        <RadialGradientBrush RadiusY="0.726" RadiusX="0.475" GradientOrigin="0.401,0.247" Center="0.347,0.121">
            <GradientStop Color="#FF9799A3" Offset="0.946"/>
            <GradientStop Color="#FFEBEBEB"/>
        </RadialGradientBrush>
    </Window.Background>

    <Grid Margin="3">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Grid.Row="0" Grid.ColumnSpan="3" Margin="1, 3, 1, 0" Name="btnGoldenModel" Tag="Create"
                        Style="{DynamicResource SimpleButton}" BorderThickness="1" BorderBrush="#888888">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Image Source="/HDSInspector;component/Images/goldenModel.png" Width="26" Height="23"  Margin="1"/>
                        <TextBlock FontSize="14" Text="골든 모델 불러오기 " VerticalAlignment="Center" Margin="5, 0, 5, 0"/>
                    </StackPanel>
                </Button>
                <!--<TextBlock VerticalAlignment="Center" Margin="5, 0, 5, 0" FontSize="16" FontWeight="UltraBold" FontFamily="Arial">기준 설비</TextBlock>-->
                <ComboBox Style="{DynamicResource SimpleComboBox}" Margin="15, 4, 4, 0" Name="cmbMachineList"
                          FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="120"/>

                <StackPanel Orientation="Horizontal" x:Name="pnlIP" Visibility="Hidden" Margin="10, 0, 0, 0">
                    <TextBlock VerticalAlignment="Center" Margin="5, 0, 5, 0" FontSize="16" FontWeight="Bold" FontFamily="Arial">IP</TextBlock>
                    <my:IPControl x:Name="txtDBIP" IsEnabled="False"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" x:Name="pnlResolution" Visibility="Hidden" Margin="10, 0, 0, 0">
                    <TextBlock VerticalAlignment="Center" Margin="5, 0, 5, 0" FontSize="16" FontWeight="Bold" FontFamily="Arial">해상도</TextBlock>
                    <TextBlock x:Name="txtResolution">0</TextBlock>
                    <TextBlock VerticalAlignment="Center" Margin="5, 0, 5, 0" FontSize="16" FontWeight="Bold" FontFamily="Arial">㎛</TextBlock>
                </StackPanel>
            </StackPanel>
            <Button x:Name="btnStart" Grid.Column="1" FontSize="14" FontWeight="UltraBold" FontFamily="Arial"
                    Style="{DynamicResource SimpleButton}" BorderThickness="1" BorderBrush="#888888">선택된 모델로 시작합니다</Button>
        </Grid>
        
        <!-- First Column -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- Center Margin -->
                <ColumnDefinition Width="5"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <!-- No. | Group -->
            <StackPanel Grid.Row="0" Margin="0, 2, 0, 0" Orientation="Horizontal">
                <StackPanel.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </StackPanel.Effect>
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
                <TextBlock Text="No." Width="50" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Text="Group" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
            </StackPanel>
            <Border Grid.Row="0" BorderBrush="#FF919191" BorderThickness="1" Margin="0, 2, 0, 0"></Border>

            <!-- listbox -->
            <ScrollViewer x:Name="svGroup" Background="White" Grid.Row="1"
                          VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible">
                <ScrollViewer.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </ScrollViewer.Effect>
                <ListBox x:Name="lbGroup" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="0"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Index}" Margin="15, 0, 0, 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Code}"  Margin="0, 0, 0, 0"/>
                                <TextBlock Grid.Column="2" Text="{Binding Name}"  Margin="15, 0, 0, 0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- No. | Model -->
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0, 2, 0, 0" Orientation="Horizontal">
                <StackPanel.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </StackPanel.Effect>
                <StackPanel.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </StackPanel.Background>
                <TextBlock Text="No." Width="50" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
                <TextBlock Text="Model" VerticalAlignment="Center" FontSize="12" Margin="10, 0, 0, 0"/>
            </StackPanel>
            <Border Grid.Row="0" Grid.Column="2" BorderBrush="#FF919191" BorderThickness="1" Margin="0, 2, 0, 0"/>

            <!-- listbox -->
            <ScrollViewer x:Name="svModel" Background="White" Grid.Row="1" Grid.Column="2" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Visible">
                <ScrollViewer.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </ScrollViewer.Effect>
                <ListBox x:Name="lbModel" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Index}" Margin="15, 0, 0, 0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="15, 0, 0, 0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>

        <!-- Model Specification -->
        <Border Grid.Row="1" Grid.Column="4" BorderBrush="#FF919191" BorderThickness="1" 
                Background="White" Margin="0, 2, 0, 0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" CornerRadius="10, 10, 0, 0" BorderThickness="0, 0, 0, 1" BorderBrush="#FF919191">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="txtModelName" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" 
                               Foreground="Black" FontSize="16" FontFamily="Arial" FontWeight="Bold" Margin="15, 0">-</TextBlock>
                </Border>
                <Grid Grid.Row="1" x:Name="pnlModelSpec">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.25*"/>
                        <ColumnDefinition Width="0.2*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label  Grid.Row="0" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">제품 길이</Label>
                    <Label  Grid.Row="1" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">제품 폭</Label>
                    <Label  Grid.Row="2" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">보정치</Label>
                    <Label  Grid.Row="3" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Scan 속도</Label>
                    <Label  Grid.Row="4" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">양품적재 수</Label>

                    <StackPanel Grid.Row="5" Grid.ColumnSpan="4" VerticalAlignment="Center" Orientation="Horizontal">
                        <StackPanel.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF919191" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </StackPanel.Background>
                        <Label FontSize="14" FontFamily="Arial" Foreground="Black" FontWeight="Bold" Margin="3, 0, 0, 0">Block 구분 정보</Label>
                    </StackPanel>

                    <Label  Grid.Row="6" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Block X-Count</Label>
                    <Label  Grid.Row="7" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Block Y-Count</Label>
                    <Label  Grid.Row="8" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Block X-Gap</Label>
                    <Label  Grid.Row="9" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Block Y-Gap</Label>

                    <StackPanel Grid.Row="10" Grid.ColumnSpan="4" VerticalAlignment="Center" Orientation="Horizontal">
                        <StackPanel.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF919191" Offset="1"/>
                                <GradientStop Color="White"/>
                            </LinearGradientBrush>
                        </StackPanel.Background>
                        <Label FontSize="14" FontFamily="Arial" Foreground="Black" FontWeight="Bold" Margin="3, 0, 0, 0">Unit 구분 정보</Label>
                    </StackPanel>

                    <Label  Grid.Row="11" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Unit X-Count</Label>
                    <Label  Grid.Row="12" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Unit Y-Count</Label>
                    <Label  Grid.Row="13" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Unit X-Pitch</Label>
                    <Label  Grid.Row="14" VerticalAlignment="Center" Margin="5, 0" FontSize="12" FontFamily="Arial">Unit Y-Pitch</Label>

                    <Label  Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label  Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label  Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label  Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial" Grid.ColumnSpan="2">mm/sec</Label>
                    <Label  Grid.Row="8" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label  Grid.Row="9" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label Grid.Row="13" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>
                    <Label Grid.Row="14" Grid.Column="2" VerticalAlignment="Center" FontSize="12" FontFamily="Arial">mm</Label>

                    <common:NumberTextBox  Grid.Row="0" Grid.Column="1" MinValue="0.0" MaxValue="300.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Width}" x:Name="txtWidth" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="1" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Height}" x:Name="txtHeight" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="2" Grid.Column="1" MinValue="0.0" MaxValue="10000.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.Align}" x:Name="txtAlign" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="3" Grid.Column="1" MinValue="0"   MaxValue="500"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding ScanVelocity}" x:Name="txtScanVelocity" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="4" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding LoadGoodCount}" x:Name="txtLoadGoodCount" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="6" Grid.Column="1" MinValue="1"   MaxValue="100"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockColumn}" x:Name="txtBlockX" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="7" Grid.Column="1" MinValue="1"   MaxValue="100"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockRow}" x:Name="txtBlockY" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="8" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockWidth}" x:Name="txtBlockPitchX" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="9" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.BlockHeight}" x:Name="txtBlockPitchY" IsEnabled="False"/>
                    <common:NumberTextBox  Grid.Row="11" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitColumn}" x:Name="txtUnitX" IsEnabled="False"/>
                    <common:NumberTextBox Grid.Row="12" Grid.Column="1" MinValue="1"   MaxValue="1000"   Round="0" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitRow}" x:Name="txtUnitY" IsEnabled="False"/>
                    <common:NumberTextBox Grid.Row="13" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitWidth}" x:Name="txtUnitPitchX" IsEnabled="False"/>
                    <common:NumberTextBox Grid.Row="14" Grid.Column="1" MinValue="0.0" MaxValue="100.0" Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding Strip.UnitHeight}" x:Name="txtUnitPitchY" IsEnabled="False"/>
                </Grid>
            </Grid>
        </Border>
        
    </Grid>
</Window>
