<Window x:Class="HDSInspector.Scrap_Strip_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HDSInspector"
        mc:Ignorable="d"
        Title="Scrap_Strip_Window" Height="1060" Width="1920" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="450"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,-80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border Grid.Column="0" Grid.Row="0" Background="Silver" CornerRadius="5,0,0,5" Margin="2" />
            <Border Grid.Column="0" Grid.Row="1" Background="Silver" CornerRadius="5,0,0,5" Margin="2" />
            <Border Grid.Column="2" Grid.Row="0" Background="Silver" CornerRadius="5,0,0,5" Margin="2" />
            <Border Grid.Column="2" Grid.Row="1" Background="Silver" CornerRadius="5,0,0,5" Margin="2" />
            <Border Grid.Row="0" Grid.Column="1" Background="WhiteSmoke"  Margin="0,1"/>
            <Border Grid.Row="0" Grid.Column="3" Background="WhiteSmoke"  Margin="0,1"/>
            <Border Grid.Row="1" Grid.Column="1" Background="WhiteSmoke"  Margin="0,1"/>
            <Border Grid.Row="1" Grid.Column="3" Background="WhiteSmoke"  Margin="0,1"/>
            <Label Grid.Row="0" Grid.Column="0" Content="폐기 스트립 수" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="#FF762A0D" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Label Name="lblScrabText1" Grid.Row="0" Grid.Column="2" Content="원소재 18개 이상" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="#FF762A0D" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Label Name="lblScrabText2" Grid.Row="1" Grid.Column="0" Content="원소재 15개 이상" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="#FF762A0D" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Label Name="lblScrabText3" Grid.Row="1" Grid.Column="2" Content="원소재 12개 이상" FontSize="20" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="#FF762A0D" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Label Grid.Column="1" Grid.Row="0" Name="lblScrab" FontSize ="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"></Label>
            <Label Grid.Column="3" Grid.Row="0" Name="lblScrab1" FontSize ="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"></Label>
            <Label Grid.Column="1" Grid.Row="1" Name="lblScrab2" FontSize ="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"></Label>
            <Label Grid.Column="3" Grid.Row="1" Name="lblScrab3" FontSize ="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"></Label>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Name="grdBads" Margin="0,80,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="1" Background="Olive" CornerRadius="5,0,0,5" Margin="0,1"/>
                <Border Grid.Row="1" Grid.ColumnSpan="1" Background="Goldenrod" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="2" Grid.ColumnSpan="1" Background="Red" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="3" Grid.ColumnSpan="1" Background="Blue" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="4" Grid.ColumnSpan="1" Background="SkyBlue" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="5" Grid.ColumnSpan="1" Background="Indigo" CornerRadius="5,0,0,5" Margin="0,1" />

                <Border Grid.Row="0" Grid.Column="3" Background="Fuchsia" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="1" Grid.Column="3" Background="Green" CornerRadius="5,0,0,5"  Margin="0,1"/>
                <Border Grid.Row="2" Grid.Column="3" Background="IndianRed" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="3" Grid.Column="3" Background="LightSlateGray" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="4" Grid.Column="3" Background="Indigo" CornerRadius="5,0,0,5" Margin="0,1" />
                <Border Grid.Row="5" Grid.Column="3" Background="Black" CornerRadius="5,0,0,5" Margin="0,1" />


                <Border Grid.Row="0" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="1" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="2" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="3" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="4" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="5" Grid.Column="1" Background="LightGray"  Margin="0,1" />
                <Border Grid.Row="0" Grid.Column="4" Background="LightGray" Margin="0,1" />
                <Border Grid.Row="1" Grid.Column="4" Background="LightGray" Margin="0,1" />
                <Border Grid.Row="2" Grid.Column="4" Background="LightGray" Margin="0,1" />
                <Border Grid.Row="3" Grid.Column="4" Background="LightGray" Margin="0,1" />
                <Border Grid.Row="4" Grid.Column="4" Background="LightGray" Margin="0,1"/>
                <Border Grid.Row="5" Grid.Column="4" Background="LightGray" Margin="0,1" />
                <Border Grid.Row="0" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="1" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="2" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="3" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="4" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="5" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="0" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="1" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="2" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="3" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="4" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Border Grid.Row="5" Grid.Column="5" Background="WhiteSmoke"  Margin="0,1"/>
                <Label Grid.Row="5" Grid.Column="4" Content="Align" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Column="1" Grid.Row="0" Content="원소재" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Column="1" Grid.Row="2" Content="Open" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Column="1" Grid.Row="3" Content="Short" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" Background="{x:Null}" HorizontalAlignment="Center"/>
                <Label Grid.Column="1" Grid.Row="1" Content="BondPad" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Column="1" Grid.Row="4" Content="Ball" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="0" Grid.Column="4" Content="PSR핀홀" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="4" Content="PSR이물질" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="2" Grid.Column="4" Content="Punch Burr" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black"  FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="3" Grid.Column="4" Content="Core Crack" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black"  FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="4" Grid.Column="4" Content="Vent Hole" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Label Grid.Row="5" Grid.Column="1" Content="Via 미충진" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text = "{Binding Path=Align}" Grid.Column="5" Grid.Row="5"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="1" Foreground="Blue" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Raw}" Grid.Column="2" Grid.Row="0"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Open}" Grid.Column="2" Grid.Row="2"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Short}" Grid.Column="2" Grid.Row="3"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=BP}" Grid.Column="2" Grid.Row="1"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Ball}" Grid.Column="2" Grid.Row="4"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=NonPSR}" Grid.Column="5" Grid.Row="0"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=PSR}" Grid.Column="5" Grid.Row="1"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Burr}" Grid.Column="5" Grid.Row="2"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Crack}" Grid.Column="5" Grid.Row="3"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Venthole}" Grid.Column="5" Grid.Row="4"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
                <TextBlock Text = "{Binding Path=Via}" Grid.Column="2" Grid.Row="5"  FontSize="25" VerticalAlignment="Center" HorizontalAlignment="Center"  Margin="1" Foreground="Black" FontWeight="Bold"/>
            </Grid>
            <Grid Grid.Column="1" Margin="0,80,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                    </StackPanel.Effect>
                    <StackPanel.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </StackPanel.Background>
                    <TextBlock Text="I D" Width="50" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" Margin="10, 0, 0, 0"/>
                    <TextBlock Text="원소재수" VerticalAlignment="Center" FontSize="15" Margin="5, 0, 0, 0"/>
                    <TextBlock Text="불량 수" VerticalAlignment="Center" FontSize="15" Margin="30, 0, 0, 0"/>
                </StackPanel>
                <ScrollViewer x:Name="svXout" Background="White"
                Grid.Row="1" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden">
                    <ScrollViewer.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                    </ScrollViewer.Effect>
                    <ListBox x:Name="lbXout" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontSize="20" Text="{Binding ID}" Margin="15, 0, 0, 0"/>
                                    <TextBlock Grid.Column="1" FontSize="20" Text="{Binding Raw}" Margin="35, 0, 0, 0"/>
                                    <TextBlock Grid.Column="2" FontSize="20" Text="{Binding XOut}"  Margin="35, 0, 0, 0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
            
        </Grid>
       
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Name="btnFirst" Grid.Column="0" FontSize="20" Margin="3"> ←처음으로</Button>
            <Button Name="btnPrev" Grid.Column="1" FontSize="20" Margin="3">이전◁</Button>
            <Button Name="btnNext" Grid.Column="3" FontSize="20" Margin="3">▷다음</Button>
            <Button Name ="btnLast" Grid.Column="4" FontSize="20" Margin="3">마지막으로→</Button>
            <Button Name="btnClose" Grid.Column="6" FontSize="20" Margin="3">나가기</Button>
            <Label Name="lblIndex" Grid.Column="2" FontSize="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">100/100</Label>
            <Border Grid.Column="5" Margin="3" CornerRadius="5" Background="Olive"></Border>
            <Label Name="lblXout" Grid.Column="5" FontSize="50" FontWeight="Bold" HorizontalContentAlignment="Center">18/18</Label>
        </Grid>
        <local:StripMap Grid.Column="4" Grid.Row="1" x:Name="map" Margin="5" />
        <ScrollViewer Name="svImage" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden" CanContentScroll="true"  Background="Silver">
            <Grid Name="grdImage" Background="White">

            </Grid>

        </ScrollViewer>
    </Grid>
</Window>
