<Window xmlns:my="clr-namespace:HDSInspector"
        xmlns:DCS="clr-namespace:DCS;assembly=DCS"
        x:Class="HDSInspector.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정" Height="550" Width="950" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>
        <TabControl Margin="5,5,5,0" Name="tbSetting" TabStripPlacement="Left" SelectedIndex="3">
            <TabItem Name="tabGeneral" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">일반</TextBlock>
                </TabItem.Header>
            </TabItem>
            <TabItem Name="tabAutoNG" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">Auto NG</TextBlock>
                </TabItem.Header>                
            </TabItem>
            <TabItem Name="tabSAP" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">SAP</TextBlock>
                </TabItem.Header>
            </TabItem>
            <TabItem Name="tabRGB" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">RGBGain</TextBlock>
                </TabItem.Header>
            </TabItem>
            <TabItem Name="tabAlgorithm" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">알고리즘</TextBlock>
                </TabItem.Header>
            </TabItem>
            <TabItem Name="tabPriority" Style="{DynamicResource BlendTabStyle}">
                <TabItem.Header>
                    <TextBlock Width="80" TextAlignment="Center" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand">우선순위</TextBlock>
                </TabItem.Header>
            </TabItem>
        </TabControl>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Grid.Row="0" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0, 0, 0, 0" Text="TEST MCR_저장 사용 여부" />
                <RadioButton Height="30" FontSize="12" Name="radUseMCRtestSaveYes" VerticalAlignment="Center" Margin="0,15,5,0">사용</RadioButton>
                <RadioButton Height="30" FontSize="12" Name="radUseMCRtestSaveNo" VerticalAlignment="Center" Margin="0,15,5,0">미사용</RadioButton>
            </StackPanel>
            <Button Name="btnDetailXML" Height="35" Width="95">자세히 보기</Button>
            <Button Name="btnSave" Height="35" Width="95" Margin="25,0,5,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Source="Images/save_file_128_128.png" Width="20" Height="20" Margin="-5, 0, 0, 0"/>
                    <TextBlock FontWeight="Normal" FontSize="12" Text="확 인" VerticalAlignment="Center" Margin="10, 0, 10, 0"/>
                </StackPanel>
            </Button>
            <Button Name="btnClose" Height="35" Width="95" Margin="5,0,10,0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
