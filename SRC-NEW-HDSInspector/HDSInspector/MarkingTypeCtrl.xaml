<UserControl x:Class="HDSInspector.MarkingTypeCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="340">
    <UserControl.Resources>
        <Style TargetType="{x:Type Label}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBarWhite}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBarWhite}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Storyboard x:Key="ShortenAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" Storyboard.TargetName="pnlMarkingSettings">
                <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard x:Key="LengthenAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" Storyboard.TargetName="pnlMarkingSettings">
                <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource ShortenAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource LengthenAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Grid.Row="2" Background="#D3D3D3">
        <Grid.RowDefinitions>
            <RowDefinition Height="23"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#4c7eb6" Offset="0.250"/>
                    <GradientStop Color="#195aa2" Offset="0.750"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Foreground="White" Margin="10, 0">마킹 파라미터 설정</TextBlock>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Name="pnlMarkingSettings" RenderTransformOrigin="0,0"
              Background="#D3D3D3">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Grid.RenderTransform>
        </Grid>



        <Grid Grid.Row="4" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Name="btnSave" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 1, 0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Source="/HDSInspector;component/Images/save_file_128_128.png" Width="20" Height="20" Margin="-2, 0, 0, 0"/>
                    <TextBlock FontWeight="Normal" Text="저 장" VerticalAlignment="Center" Margin="5, 0, 0, 0"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="1" Name="btnSetPreview" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">직전값 복원</Button>
            <Button Grid.Column="2" Name="btnSetDefault" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">기본값</Button>
            <Button Grid.Column="3" Name="btnDelete"     Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 0, 0">삭 제</Button>
        </Grid>
    </Grid>
</UserControl>