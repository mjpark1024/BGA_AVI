<UserControl x:Class="HDSInspector.InspectionResultItem"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HDSInspector"
      mc:Ignorable="d" 
      d:DesignHeight="25" d:DesignWidth="100">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.Column="1" Background="LightGray"  Margin="0,1" />
        <Border Grid.Row="0" Grid.Column="2" Background="WhiteSmoke"  Margin="0,1"/>
        <Border Name="badColor" Grid.Row="0" Background="Olive" CornerRadius="5,0,0,5" Margin="0,1"/>
        <Label Name="badName" Grid.Row="0" Grid.Column="1" Content="불량이름" FontSize="11" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Name="badCount" Grid.Row="0" Grid.Column="2"  FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Blue" FontWeight="Bold"/>
    </Grid>
</UserControl>
