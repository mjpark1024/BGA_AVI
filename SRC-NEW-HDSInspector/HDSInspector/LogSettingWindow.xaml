<Window xmlns:my="clr-namespace:HDSInspector"  x:Class="HDSInspector.LogSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:Common;assembly=Common"
        Title="로그 설정" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Height="700" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <my:LogCtrl Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0"/>
        <Grid Grid.Row="0" Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="1" Grid.RowSpan="6" Grid.ColumnSpan="2" BorderBrush="#495d7f" BorderThickness="1, 0, 1, 1" Margin="0, -1, 0, -1"/>
            <Border Grid.Row="1" Grid.RowSpan="5" Background="#AADDDDDD" Margin="1, 0, 0, 0"/>
            <Border BorderBrush="#FF919191" BorderThickness="1" Grid.ColumnSpan="2" Margin="0, 0, 0, 0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="Local Log Setting" Margin="15, 0" FontWeight="Bold" Foreground="Black" FontSize="12" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.RowSpan="2" Text="로그 저장" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0"/>
            <Grid Grid.Row="1" Grid.Column="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Name="radSaveLogYes" Content="예" Margin="10, 0"/>
                    <RadioButton Name="radSaveLogNo" Content="아니오" Margin="10, 0"/>
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
                <Ellipse Width="12" Height="12" Margin="10, 0, 5, 0">
                    <Ellipse.Stroke>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black" Offset="1"/>
                            <GradientStop Color="#FFDEDEDE"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.368,0.171" GradientOrigin="0.379,0.19" RadiusX="0.616" RadiusY="0.674">
                            <GradientStop Color="#FF0C548B" Offset="0.985"/>
                            <GradientStop Color="White"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Name="txtSaveLogHelper" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Text="로컬 파일시스템에 로그를 저장합니다" />
            </StackPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="로그 보관 일수" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 0"/>
            <Grid Grid.Row="3" Grid.Column="1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <common:NumberTextBox Name="txtKeepDate" MinValue="1" MaxValue="90" Round="0"
                                          VerticalAlignment="Center" Margin="10, 0" Width="70">                        
                    </common:NumberTextBox>
                    <TextBlock VerticalAlignment="Center" Text="일"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="4" Text="로그 저장 레벨" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 5, 0, 0"/>
            <Grid Grid.Row="4" Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <ComboBox Name="cbLocalSaveLevelSelector" Style="{StaticResource ComboBoxStyle1}" Margin="10,5,10,0" FontSize="12" FontWeight="Bold" Width="70" Height="26"/>
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="이상 저장"/>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="UI 표시 레벨" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20, 0, 0, 5"/>
            <Grid Grid.Row="5" Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <ComboBox Name="cbDisplayLevelSelector"  Style="{StaticResource ComboBoxStyle1}" Margin="10, 3" FontSize="12" FontWeight="Bold" Width="70" Height="26"/>
                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="이상 표시"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="1" Margin="0,5,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="1" Grid.RowSpan="5" Grid.ColumnSpan="2" BorderBrush="#495d7f" BorderThickness="1, 0, 1, 1" Margin="5, -1, 0, -1"/>
            <Border Grid.Row="1" Grid.RowSpan="5" Background="#AADDDDDD" Margin="6, 0, 0, 0"/>
            <Border BorderBrush="#FF919191" BorderThickness="1" Grid.ColumnSpan="2" Margin="5, 0, 0, 0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="Log Level Information" Margin="15, 0" FontWeight="Bold" Foreground="Black" FontSize="12" VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Row="2" Grid.Column="0">
                <TextBlock FontSize="12" Text="DEBUG"   FontWeight="Bold" HorizontalAlignment="Left" Margin="20, 10, 0, 2"/>
                <TextBlock FontSize="12" Text="INFO"    FontWeight="Bold" HorizontalAlignment="Left" Margin="20, 10, 0, 2"/>
                <TextBlock FontSize="12" Text="WARNING" FontWeight="Bold" HorizontalAlignment="Left" Margin="20, 10, 0, 2"/>
                <TextBlock FontSize="12" Text="ERROR"   FontWeight="Bold" HorizontalAlignment="Left" Margin="20, 10, 0, 2"/>
                <TextBlock FontSize="12" Text="FATAL"   FontWeight="Bold" HorizontalAlignment="Left" Margin="20, 10, 0, 2"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="10, 0">
                <TextBlock FontSize="12" Margin="2,10,0,0" Text="엔지니어의 유지,보수 목적으로 사용됩니다."/>
                <TextBlock FontSize="12" Margin="2,12,0,0" Text="프로그램에 대한 호출 흐름을 나타냅니다."/>
                <TextBlock FontSize="12" Margin="2,12,0,0" Text="복구 가능한 사소한 오류에 대한 정보입니다."/>
                <TextBlock FontSize="12" Margin="2,12,0,0" Text="발생한 예외에 대한 정보입니다."/>
                <TextBlock FontSize="12" Margin="2,12,0,0" Text="치명적인 오류에 대한 정보입니다."/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="btnLogDialog" Margin="10,0,20,0" Height="35" Width="95">로그 열기</Button>
                <Button Name="btnOK" Margin="10, 0" Height="35" Width="95">확 인</Button>
                <Button Name="btnCancel" Margin="10, 0" Height="35" Width="95">취 소</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
