<Window xmlns:my ="clr-namespace:HDSInspector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDSInspector" x:Class="HDSInspector.LaserWindow"
        Title="LaserWindow" Height="1000" Width="1920" WindowStyle ="None" SizeToContent="Height" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1200*"/>
            <ColumnDefinition Width="517"/>
        </Grid.ColumnDefinitions>
        <my:MarkViewerCtrl x:Name="viewer"></my:MarkViewerCtrl>
        <Grid Grid.Column="1">
        
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="516"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="388"/>
                
                <RowDefinition Height="140"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Row="3" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Label Grid.Column="0" Grid.Row="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="2" BorderThickness="2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="현재 위치"/>
                <Label Grid.Column="2" Grid.Row="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="2" BorderThickness="2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="저장 위치" />
                <Label Grid.Column="0" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,1,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="보트 위치" />
                <Label Grid.Column="0" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,1,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="카메라 위치" />
                <Label Grid.Column="2" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,1,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="보트 1 위치" />
                <Label Grid.Column="2" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,2,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="보트 2 위치" />
                <Label Grid.Column="2" Grid.Row="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,2,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="카메라 위치" />
                <Label Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="White"
				    x:Name="lblCurrentBoatPos" Foreground="Black" Grid.ColumnSpan="1" BorderThickness="2,1,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="00.00" />
                <Label Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="White"
				    x:Name="lblCurrentCamPos" Foreground="Black" Grid.ColumnSpan="1" BorderThickness="2,1,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="00.00" />
                <Label Grid.Column="3" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="White"
				    x:Name="lblAlignPos1" Foreground="Black" Grid.ColumnSpan="1" BorderThickness="2,1,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="00.00" />
                <Label Grid.Column="3" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="White"
				    x:Name="lblAlignPos2" Foreground="Black" Grid.ColumnSpan="1" BorderThickness="2,2,2,1" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="00.00" />
                <Label Grid.Column="3" Grid.Row="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="White"
				    x:Name="lblAlignPos" Foreground="Black" Grid.ColumnSpan="1" BorderThickness="2,2,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="00.00" />
                <Button x:Name="btnSaveDefaultPos" Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2" FontSize="20" Margin="3" Content="기준 위치로 등록"/>
                <Button Name="btnClose" Grid.Row="5" Grid.RowSpan="2" Grid.Column="4"  FontSize="20" Margin="3" >나가기</Button>
                <Button Grid.Row="4" Grid.Column="0" Margin="3" Name="btnRetry" FontSize="10">레이저 재접속</Button>
                <Label Grid.Row="4" Grid.Column="1" FontSize="13" HorizontalAlignment="Right" Width="60" Margin="8,8,15,8">연결상태</Label>
                <local:LedLamp x:Name="lampConnect" Grid.Column="1" HorizontalAlignment="Left" Height="30" Margin="8" Grid.Row="4" VerticalAlignment="Top" Width="30"/>
                <Grid Grid.Row="5" Grid.ColumnSpan="3" Grid.RowSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Label Grid.Column="0" Grid.Row="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,2,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="일치율" />
                    <Label Grid.Column="0" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="15" Background="Gray"
				    Foreground="White" Grid.ColumnSpan="1" BorderThickness="2,2,2,2" BorderBrush="White" FontFamily="Franklin Gothic Demi" Content="Mark File" Visibility="Hidden" />
                    <TextBox x:Name="txtAlignMatch" Grid.Row="0" Grid.Column="1" Margin="4" FontSize="22" Text="60" Width="60" HorizontalAlignment="Left"/>
                    <Button x:Name="btnSaveMatch" Grid.Column="1" Grid.Row="0" FontSize="20" Margin="3" Content="설정" Width="100" HorizontalAlignment="Right"/>
                    <Label Name="lblMarkFile" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" VerticalContentAlignment="Center" FontSize="20" Margin="1" Visibility="Hidden">623S31.mrk</Label>
                    
                </Grid>
            </Grid>
            <Grid Grid.Row="0" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" FontSize="20" Margin="3" Name="btnAlign">Align</Button>
                <Button Grid.Column="1" FontSize="20" Margin="3" Name="btnMarking">마킹</Button>
                <Button Grid.Column="2" Name="btnSave" FontSize="20" Margin="3">전체 저장</Button>
                <Grid Background="Silver" Grid.Row="1" Grid.ColumnSpan="3">
                    <Grid Grid.Row="0" Grid.ColumnSpan="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Row="0" Grid.Column="1" FontSize="15" Name="txtWeek" Margin="0,3">0000</TextBox>
                        <Label Grid.Row="0" Grid.Column="0" FontSize="15" HorizontalAlignment="Right" Width="80">제조주차</Label>
                        
                    </Grid>


                </Grid>
            </Grid>
            <Grid Grid.Column="1" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="388"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Canvas x:Name="LiveCanvas" Grid.ColumnSpan="2" Height="410" HorizontalAlignment="Stretch" Margin="2" VerticalAlignment="Stretch" Width="512" Background="Black">
                    <Line StrokeThickness="2" X1="256" X2="256" Y1="0" Y2="384" Stroke="Red" ></Line>
                    <Line StrokeThickness="2" X1="0" X2="512" Y1="192" Y2="192" Stroke="Red" ></Line>
                    <Rectangle Name="rctAlign1" Width="32" Height="32" Stroke="Yellow" StrokeThickness="2"></Rectangle>
                    <Rectangle Name="rctAlign2" Width="32" Height="32" Stroke="Fuchsia" StrokeThickness="2" Canvas.Left="20" Canvas.Top="20"></Rectangle>
                    <Image Height="384" Margin="0" x:Name="imgLive" OpacityMask="#D6F5E2E2" Stretch="Fill" Width="512" Tag="1"/>
                </Canvas>
                <Button Name="btnROI" Width="100" Height="40" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="5" FontSize="15">ROI SET</Button>

            </Grid>
            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300*"/>
                    <ColumnDefinition Width="300*"/>
                </Grid.ColumnDefinitions>
                
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Canvas x:Name="AlignCanvasLeft" Grid.Column="0" Grid.Row="1" Grid.RowSpan="5" Height="104" HorizontalAlignment="Stretch" Margin="2" VerticalAlignment="Stretch" Width="104" Background="Black">
                        <Image Height="100" HorizontalAlignment="Left" x:Name="imgAlignLeft" Stretch="Fill" VerticalAlignment="Top" Width="100" Margin="2"/>
                    </Canvas>
                
                    <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14" FontWeight="Bold" Content="Left Align">
                        <Label.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF747474" Offset="0"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Label.Background>
                    </Label>
                    <Label Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="X :"/>
                    <Label Grid.Column="3" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="Y :"/>
                    <Label Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="M :"/>
                    <Label Grid.Column="3" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="A :"/>
                    <Label x:Name="lblOffsetXLeft" Grid.Column="2" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Label x:Name="lblOffsetYLeft" Grid.Column="4" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Label x:Name="lblMatchLeft" Grid.Column="2" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Label x:Name="lblAngle" Grid.Column="4" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Button x:Name="btnInspectAlignLeft" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="4" Grid.RowSpan="2" Margin="5" FontSize="20" Content="Align 확인"/>
                    <ComboBox Name="cbPos" SelectedIndex="0" Visibility="Hidden">
                        <ComboBoxItem Content="Right"/>
                        <ComboBoxItem Content="Left"/>
                    </ComboBox>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="104"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="50"/>
                    
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Canvas x:Name="AlignCanvasRight" Grid.Column="0" Grid.Row="1" Grid.RowSpan="5" Height="104" HorizontalAlignment="Stretch" Margin="2" VerticalAlignment="Stretch" Width="104" Background="Black">
                        <Image Height="100" HorizontalAlignment="Left" Margin="2" x:Name="imgAlignRight" Stretch="Fill" VerticalAlignment="Top" Width="100" />
                    </Canvas>
                    <Label Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14" FontWeight="Bold" Content="Right Align">
                        <Label.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF747474" Offset="0"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Label.Background>
                    </Label>
                    <Label Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="X :"/>
                    <Label Grid.Column="3" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="Y :"/>
                
                    <Label Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" FontSize="13" Content="M :"/>
                    <Label x:Name="lblOffsetXRight" Grid.Column="2" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Label x:Name="lblOffsetYRight" Grid.Column="4" Grid.Row="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                
                    <Label x:Name="lblMatchRight" Grid.Column="2" Grid.Row="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" FontSize="15" Content="0"/>
                    <Button x:Name="btnInspectAlignRight" Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="4" Grid.RowSpan="2" Margin="5" FontSize="20" Content="Align 확인"/>
                </Grid>
                
            </Grid>
        </Grid>
        <Button  HorizontalAlignment="Right" Height="50" Margin="2,5,254,2" VerticalAlignment="Top" Width="75" Name="btnRegistRef">
            <StackPanel Orientation="Vertical">
                <Label HorizontalAlignment="Center">기준영상</Label>
                <Label HorizontalAlignment="Center" Margin="0,-5,0,0">재등록</Label>
            </StackPanel>
        </Button>
    </Grid>
</Window>
