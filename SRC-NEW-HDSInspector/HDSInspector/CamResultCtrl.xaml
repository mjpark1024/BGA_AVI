<UserControl x:Class="HDSInspector.CamResultCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HDSInspector"
             xmlns:sub="clr-namespace:HDSInspector.SubControl"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="632">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="225"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="DarkGray" BorderThickness="3" CornerRadius="6" Grid.RowSpan="2" Margin="2,5,2,5"/>
        <Grid  Grid.RowSpan="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition />
                <RowDefinition  Height="130"/>
            </Grid.RowDefinitions>

            <Button Name="btnLC" Margin="1,4,0,4" HorizontalAlignment="Left" Width="38">
                <StackPanel>
                    <Label FontSize="12" FontWeight="Bold">조명</Label>
                    <Label FontSize="12" FontWeight="Bold">변경</Label>
                </StackPanel>
            </Button>
            <TextBlock Name="txtTitle" Grid.Row="1" TextAlignment="Center" FontSize="25" FontWeight="Bold" Width="25" TextWrapping="Wrap" VerticalAlignment="Center">BA외관 1</TextBlock>
            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Name="lblPosX" FontSize="14" HorizontalContentAlignment="Center" FontWeight="Bold">X:00</Label>
                <Label Grid.Row="1" Name="lblPosY" FontSize="14" HorizontalContentAlignment="Center" FontWeight="Bold">Y:00</Label>
                <Label Grid.Row="2" Name="lblRV" FontSize="17" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,-5,0,0">255</Label>
                <Label Grid.Row="3" Name="lblGV" FontSize="17" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,-5,0,0">255</Label>
                <Label Grid.Row="4" Name="lblBV" FontSize="17" HorizontalContentAlignment="Center" FontWeight="Bold" Margin="0,-5,0,0">255</Label>
            </Grid>
        </Grid>
        <local:StripMap Grid.Column="6" Grid.Row="0" Margin="2" x:Name="Map" />
        <Grid Grid.Column="1" Grid.Row="1" Margin="2">
            <Grid x:Name="GridResultimage" />

            <Grid Name="grdLC" Grid.Column="3" Grid.ColumnSpan="3" Background="White" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="23"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <sub:LightChange x:Name="lc" Grid.ColumnSpan="2"></sub:LightChange>
                <Button Grid.Row="1" Grid.Column="0" Name="btnSaveLight" Margin="2">적용</Button>
                <Button Grid.Row="1" Grid.Column="1" Name="btnCancelLight" Margin="2">취소</Button>
            </Grid>
        </Grid>
        <Border Grid.Column="1" Grid.RowSpan="2" Background="Silver" Opacity="0.6" Name="bdrSkip">
            <TextBlock FontSize="80" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Text="검사&#10;SKIP"/>
        </Border>
    </Grid>
</UserControl>
