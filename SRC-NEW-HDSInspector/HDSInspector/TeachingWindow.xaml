<Window x:Class="HDSInspector.TeachingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
        xmlns:common="clr-namespace:Common;assembly=Common"
        WindowStartupLocation="CenterScreen"
        Title="모델 티칭" 
        Icon="Images/mts_icon.ico"
        MinHeight="1024" MinWidth="1280" Height="1024" Width="1280" WindowState="Maximized"
        HorizontalAlignment="Center" VerticalAlignment="Center"
        xmlns:my="clr-namespace:HDSInspector" 
        xmlns:my1="clr-namespace:DCS;assembly=DCS" 
        xmlns:my2="clr-namespace:Common.Control;assembly=Common.Control">
    <Window.Resources>
        <common:DoubleToDecimalConverter x:Key="doubleToDecimalconverter"/>
        <Storyboard x:Key="Storyboard1" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="txtStatus">
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource Storyboard1}"/>
        </EventTrigger>
    </Window.Triggers>
    <Window.Background>
        <RadialGradientBrush RadiusY="0.726" RadiusX="0.475" GradientOrigin="0.151,0.147" Center="0.467,0.421">
            <GradientStop Color="#CCCCCC" Offset="0.846"/>
            <GradientStop Color="White"/>
        </RadialGradientBrush>
    </Window.Background>
    <Grid x:Name="pnlMain">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3.5*"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Teaching Viewer -->
        <my:TeachingViewer x:Name="TeachingViewer" Grid.RowSpan="2" Grid.Row="0"/>
        <Grid  Width="300" Margin="3" Height="30" VerticalAlignment="Top" HorizontalAlignment="Right" Name="grdSelectRGB" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="4" Background="Silver" CornerRadius="5"></Border>
            <RadioButton Name="rdRed" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" GroupName="a" IsChecked="True" Tag="RED">Red</RadioButton>
            <RadioButton Name="rdGreen" FontSize="15" FontWeight="Bold" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" GroupName="a" Tag="GREEN">Green</RadioButton>
            <RadioButton Name="rdBlue" FontSize="15" FontWeight="Bold" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" GroupName="a" Tag="BLUE">Blue</RadioButton>
            <RadioButton Name="rdRGB" FontSize="15" FontWeight="Bold" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" GroupName="a" Tag="RGB">Color</RadioButton>
        </Grid>
        <Grid  Width="300" Margin="3" Height="30" VerticalAlignment="Top" HorizontalAlignment="Right" Name="grdCampitch" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label  Grid.Column="0" VerticalAlignment="Center"  FontSize="14" FontFamily="Arial">CAM1 피치</Label>
            <common:NumberTextBox Grid.Column="1" MinValue="-20.0"  MaxValue="20.0"  Round="2" VerticalContentAlignment="Center" Margin="4" Text="{Binding XPitch, Mode=OneWay}" x:Name="txtXPitch"/>
            <Button Grid.Column="2" Height="25" Content="적용"  x:Name="btn_Campitch" />
        </Grid>
        <!-- Teaching Quick Utility -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2" SnapsToDevicePixels="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Name="btnLoadImage" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="영상 열기">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/load_frame.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="30" Width="30"/>
                    </StackPanel>
                </Button>
                <Button Name="btnSaveImage" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="영상 저장" Grid.Column="1">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/save_file_128_128.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="30" Width="30"/>
                    </StackPanel>
                </Button>
                <Button Name="btnLoadXML" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="데이터 복원 (XML)" Grid.Column="2">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/load_roi.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="32" Width="32"/>
                    </StackPanel>
                </Button>
                <Button Name="btnSaveXML" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="데이터 추출 (XML)" Grid.Column="3">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/save_roi.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="32" Width="32"/>
                    </StackPanel>
                </Button>
                <Button Name="btnParaSetting" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="파라매터 설정" Grid.Column="4">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/database.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="32" Width="42"/>
                    </StackPanel>
                </Button>
                <Button Name="btnQuestion" Style="{StaticResource NullBackgroundButtonStyle}" ToolTip="단축키 도움말" Grid.Column="5">
                    <StackPanel Width="Auto" Height="Auto">
                        <Image Source="/HDSInspector;component/Images/question.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="32" Width="42"/>
                    </StackPanel>
                </Button>
            </Grid>
            <TextBlock Grid.Column="1" FontFamily="Arial" FontWeight="UltraBold" FontSize="18" Foreground="#144B92" HorizontalAlignment="Center" VerticalAlignment="Center" Name="txtStatus" Text="" Margin="0, 0, 40, 0"/>
            <Button Name="btnClose" Style="{StaticResource NullBackgroundButtonStyle}" Width="58" Grid.Column="1" ToolTip="닫기" HorizontalAlignment="Right" Cursor="Hand">
                <StackPanel Width="Auto" Height="Auto">
                    <Image Source="/HDSInspector;component/Images/login.png" HorizontalAlignment="Center" VerticalAlignment="Top" Height="30" Width="30"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>
            <!-- 영상 취득, 섹션 생성, 기준영상 등록, 티칭 정보저장 -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSaveGoldenModel" Grid.Column="0" Grid.ColumnSpan="1"  Grid.Row="0" Cursor="Hand"
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0" Margin="3">
                    <StackPanel Orientation="Horizontal" Margin="15, 0, 0, 0" Width="150">
                        <Image Source="/HDSInspector;component/Images/goldenModel.png" Width="26" Height="23"  Margin="1"/>
                        <TextBlock Text="골든 저장하기" FontWeight="Bold" VerticalAlignment="Center" Margin="3, 0, 0, 0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnGrabFullImage" Grid.Column="1" Grid.Row="0" Cursor="Hand" ToolTip="전체 영상 취득" 
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0" Margin="3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/HDSInspector;component/Images/livecam.png" Width="18" Margin="1"/>
                        <TextBlock Text="전제영상취득(주의)" FontWeight="Bold" VerticalAlignment="Center" Margin="3, 0, 0, 0" Foreground="Red"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnGrabEntireImage" Grid.Column="2" Grid.Row="1" Cursor="Hand" ToolTip="티칭 영상 취득 (F5)" 
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0" >
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/HDSInspector;component/Images/livecam.png" Width="18" Margin="1"/>
                        <TextBlock Text="티칭 영상 취득" FontWeight="Bold" VerticalAlignment="Center" Margin="3, 0, 0, 0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnCreateSection" Grid.Column="0" Grid.Row="1" Cursor="Hand"
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/HDSInspector;component/Images/small_refresh.png" Width="18" Margin="1"/>
                        <TextBlock Text="섹션 생성" FontWeight="Bold" VerticalAlignment="Center" Margin="3, 0, 0, 0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnRegisterBasedImage" Grid.Row="2" Grid.Column="0" Cursor="Hand"
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/HDSInspector;component/Images/save_file_128_128.png" Width="18" Margin="1"/>
                        <TextBlock Text="기준영상 등록" FontWeight="Bold" Margin="2, 0, 0, 0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnSaveTeachingData" Grid.Row="2" Grid.Column="1" Cursor="Hand"
                        Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="1, 1, 0, 0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Source="/HDSInspector;component/Images/database.png" Width="18" Margin="1"/>
                        <TextBlock Text="티칭 정보저장" FontWeight="Bold" Margin="3, 0, 0, 0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
            <!-- 검사 방법 설정 -->
            <my:InspectionTypeCtrl x:Name="InspectionTypectrl" Grid.Row="1" Grid.Column="1" />
            <!-- Histogram Control -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FF919191" BorderThickness="1, 1, 0, 1" Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial" FontWeight="Bold"
                                   Width="80" VerticalAlignment="Center" Margin="15, 0, 0, 0">ROI Histogram</TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="White" BorderBrush="Silver" BorderThickness="1, 1, 0, 1">
                    <my:HistogramCtrl x:Name="HistogramCtrl" HorizontalContentAlignment="Stretch" VerticalAlignment="Top" Margin="0, 0, 10, 0" Height="160"/>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="2" Grid.Row="2" Name="pnlRight">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="284"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>
            <Border BorderBrush="#888888" BorderThickness="1" Grid.Row="0"/>
            <Border BorderBrush="#888888" BorderThickness="1" Grid.Row="1"/>
            <!-- 수동 검사 -->
            <Grid Grid.Row="0" Margin="1, 0, 0, 0" Background="Silver" x:Name="pnlManualInspect">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="140"/>
                    <RowDefinition/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="100*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="25*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#FF919191" BorderThickness="0, 1, 1, 1" Grid.Row="0" Grid.ColumnSpan="5">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial" FontWeight="Bold" Width="80" VerticalAlignment="Center" Margin="15, 0, 0, 0">수동 검사</TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="0" Grid.Row="2" Margin="0,2,0,-2" VerticalAlignment="Top" MaxHeight="106">
                    <common:AntiAliasedImage HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="./Images/REF.png" Name="ImgRef"/>
                </Border>
                <Border Grid.Column="2" Grid.Row="2" Margin="0,2,0,-2" VerticalAlignment="Top" MaxHeight="106">
                    <common:AntiAliasedImage HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="./Images/DEF.png" Name="ImgDef"/>
                </Border>
                <Border Grid.Column="2" Grid.Row="2" Margin="0,2,0,-2" VerticalAlignment="Top" MaxHeight="106">
                    <common:AntiAliasedImage HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="./Images/DEF.png" Name="ImgRefTrans" Opacity="0"/>
                </Border>
                <ComboBox Grid.Row="2" Grid.Column="0" x:Name="cmbRegionList" Height="29"  FontSize="13" FontWeight="Bold" VerticalAlignment="Bottom"
                            VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Style="{DynamicResource SimpleComboBox}" Margin ="1,3,0,1"/>
                <Button Name="btnViewUnit" Grid.Column="2" Content="유닛 보기" Height="30"  Grid.Row="2" Style="{DynamicResource SimpleButton}" Margin="3,0,0,0"
                        VerticalAlignment="Bottom" BorderBrush="#888888" BorderThickness="1"/>
                
    
                <Slider Orientation="Vertical" Grid.Row="2" Grid.Column="4" Margin="0,2,0,28" HorizontalAlignment="Center" VerticalAlignment="Top" Height="98" Name="sdRefOpacity" Minimum="0.0" Maximum="1.0"></Slider>

                <ListView Name="lvResult" SelectionMode="Single" Grid.Row="3" Grid.ColumnSpan="5" Margin="4,2,2,2" ScrollViewer.CanContentScroll="true" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="번호" DisplayMemberBinding="{Binding SortedIndex}" Width="35"/>
                            <GridViewColumn Header="검사 방법" DisplayMemberBinding="{Binding InspType}" Width="80"/>
                            <GridViewColumn Header="유닛 위치" DisplayMemberBinding="{Binding ResPosition}"/>
                            <GridViewColumn Header="불량 구분" DisplayMemberBinding="{Binding ResultName}" Width="80"/>
                            <GridViewColumn Header="불량 크기" DisplayMemberBinding="{Binding DefectSize, Converter={StaticResource doubleToDecimalconverter}, ConverterParameter=2}"/>
                            <!--<GridViewColumn Header="불량 위치" DisplayMemberBinding="{Binding StripDefectCenter}"/>-->
                        </GridView>
                    </ListView.View>
                </ListView>
                <TextBlock Grid.Row="3" Grid.ColumnSpan="5" Foreground="DarkGray" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" FontFamily="Arial" FontWeight="Bold" FontSize="30" 
                           Name="txtNoNG">
                    불량 없음
                </TextBlock>
                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="5" Margin="5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Label Margin="0,-5,0,0" FontSize="13">Strip ID :</Label>
                    <Label Name="lblStripID" Grid.Column="1" Margin="0,-5,0,0" FontSize="13">12354134541</Label>
                    <CheckBox Grid.Row="2" Grid.Column="2" x:Name="ck_Remove_duplicates" VerticalAlignment="Center" HorizontalAlignment="Right" Content="중복제거" IsChecked="True"></CheckBox>

                </Grid>
                <Grid Grid.Row="1" Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Name="btnSendPara" Cursor="Hand" ToolTip="비전 전송 (F6)" Style="{DynamicResource SimpleButton}"
                            BorderBrush="#888888" BorderThickness="0, 1, 1, 1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="Normal" Text="비전 전송" VerticalAlignment="Center" Margin="3, 0, 3, 0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Name="btnPartialInspect" Cursor="Hand" ToolTip="부분 검사 (F7)"  Style="{DynamicResource SimpleButton}"
                            BorderBrush="#888888" BorderThickness="0, 1, 1, 1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock FontWeight="Normal" Text="이미지전송" VerticalAlignment="Center" Margin="3, 0, 3, 0"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Name="btnManualInspect" Cursor="Hand" ToolTip="전체 검사 (F8)"  Style="{DynamicResource SimpleButton}"
                            BorderBrush="#888888" BorderThickness="0, 1, 1, 1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock FontWeight="Normal" Text="전체 검사" VerticalAlignment="Center" Margin="3, 0, 3, 0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
            <!-- 조명 설정 -->
            <Grid Grid.Row="1" Margin="1, 0, 0, 0" x:Name="pnlLight">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FF919191" BorderThickness="1" Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial" FontWeight="Bold" Width="80" VerticalAlignment="Center" Margin="15, 0, 0, 0">조명 설정</TextBlock>
                    </StackPanel>
                </Border>
                <my1:LightControl Grid.Row="1" Name="lightcontrol" Background="White"/>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Name="btnONOFF"  Grid.Column="0" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">ON</Button>
                    <Button Grid.Column="1" Name="btnSave"   Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Image Source="/HDSInspector;component/Images/save_file_128_128.png" Width="20" Height="20" Margin="-5, 0, 0, 0"/>
                            <TextBlock FontWeight="Normal" Text="저 장" VerticalAlignment="Center" Margin="10, 0, 10, 0"/>
                        </StackPanel>
                    </Button>
                    <Button Name="btnCancel" Grid.Column="2" Style="{DynamicResource SimpleButton}" BorderBrush="#888888" BorderThickness="0, 1, 1, 0">취 소</Button>
                </Grid>
            </Grid>
            <!-- Line Profile Control -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border BorderBrush="#FF919191" BorderThickness="0, 1, 1, 1" Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FF919191" Offset="1"/>
                            <GradientStop Color="White"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="12" FontFamily="Arial" FontWeight="Bold" Width="80" VerticalAlignment="Center" Margin="15, 0, 0, 0">Line Profile</TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="White" BorderBrush="Silver" BorderThickness="0, 1, 1, 1">
                    <my:LineProfileCtrl x:Name="LineProfileCtrl" HorizontalContentAlignment="Stretch" VerticalAlignment="Top" Margin="0, 0, 10, 0" Height="160"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
