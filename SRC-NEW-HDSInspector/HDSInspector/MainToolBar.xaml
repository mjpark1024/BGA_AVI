<UserControl x:Class="HDSInspector.MainToolBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:my="clr-namespace:HDSInspector"
             mc:Ignorable="d" d:DesignHeight="48" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Height="Auto" Width="Auto">
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70*" />
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="140*"/>
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="70" />
            <ColumnDefinition Width="1" />
        </Grid.ColumnDefinitions>

        <!-- 검 사 대 기 -->
        <!-- 대 기 -->
        <!--<Label Name="lblResult" Grid.Column="16" HorizontalContentAlignment="Center"  VerticalContentAlignment="Center" FontSize="30" 
               BorderBrush="#FF5C5C5C" BorderThickness="0, 1, 0, 1" FontWeight="UltraBold" FontFamily="헤드라인">대  기</Label> -->
        <Button Grid.Column="16"  Template="{DynamicResource MenuButtonStyle2}" ></Button>
        <Button Grid.Column="1"  Name="toolButton1" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="ModelManager">모델 관리</Button>
        <Button Grid.Column="3"  Name="toolButton2" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="ModelTeaching">모델 티칭</Button>
        <Button Grid.Column="5"  Name="toolButton3" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="InspectionResult">검사 결과</Button>
        <Button Grid.Column="7"  Name="toolButton4" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="MarkingLaser">레이저 마킹</Button>
        <Button Grid.Column="11" Visibility="Hidden" Name="toolButton5" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="SettingLog">로그 설정</Button>
        <Button Grid.Column="11" Name="toolButton6" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="Configure">환경 설정</Button>
        <Button Grid.Column="13" Name="toolButton10" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="Scrap">폐기 확인</Button>
        <Button Grid.Column="9" Name="toolButton7" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="Inspection" Style="{StaticResource NullBackgroundButtonStyle}">
            <Image Name="ImgInspect" Source="/HDSInspector;component/Images/start2.png" Margin="10,10,10,10"/>
        </Button>
        <Button Grid.Column="15" Name="toolButton8" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="ChangeUser" Visibility="Hidden">작업자 변경</Button>
        <Border Grid.Column="0" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="2" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="4" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="6" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="8" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="10" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="10" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="12" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="14" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Column="16" BorderBrush="#FF5C5C5C" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF5C5C5C" Offset="1"/>
                    <GradientStop Color="#EDEDED"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Button Grid.Column="17" Name="toolButton9" Template="{DynamicResource MenuButtonStyle2}" Cursor="Hand" Tag="Close" Style="{StaticResource NullBackgroundButtonStyle}">
            <Image Source="/HDSInspector;component/Images/off.png" Width="40" Height="40"/>
        </Button>
        <Border Grid.Column="15" BorderBrush="Silver" BorderThickness="1">
            <Label FontSize="35" FontWeight="Bold" Margin="0" HorizontalAlignment="Center" Name="lblStatus">검사대기</Label>
        </Border>
    </Grid>
</UserControl>
