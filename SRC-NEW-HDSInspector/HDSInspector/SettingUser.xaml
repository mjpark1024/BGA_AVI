<UserControl x:Class="HDSInspector.SettingUser"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="130"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2"  Margin="0,5,0,10" Name="grdCurrentUser">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.RowSpan="5" Grid.ColumnSpan="6" BorderBrush="DarkGray" BorderThickness="1" />
            <Border Grid.Row="1" Grid.RowSpan="2" Background="#AADDDDDD" Margin="1, 0, 0, 0"/>
            <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" Background="#AADDDDDD" Margin="1, 0, 0, 0"/>
            <Border Visibility="Hidden" Grid.Row="1" Grid.Column="4" Grid.RowSpan="1" Background="#AADDDDDD" Margin="1, 0, 0, 0"/>
            <Border CornerRadius="0,0,0,0" Grid.ColumnSpan="6" Margin="1,1,1,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="현재 사용자 정보" Margin="5,1,0,0" FontWeight="Bold" Foreground="Black" FontSize="12" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Grid.Row="1" Text="이 름" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="18, 5, 0, 0"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="사 번" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="18, 0, 0, 5"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="변경 권한" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8, 0, 0, 5"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="변경 여부" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8, 5, 0, 0"/>
            <TextBlock Grid.Row="1" Grid.Column="4" Visibility="Hidden" Text="사용 시간" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="8, 0, 0, 5"/>

            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path=Name, Mode=TwoWay}" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Path=BusinessNumber, Mode=TwoWay}" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Path=Changed, Mode=TwoWay}" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding Path=Author, Mode=TwoWay}" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
            <TextBlock Grid.Row="1" Grid.Column="5" Visibility="Hidden" Text="{Binding Path=RunTime, StringFormat=hh\\:mm\\:ss, TargetNullValue= ' --- '}" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="2"  Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.RowSpan="5" Grid.ColumnSpan="2" BorderBrush="DarkGray" BorderThickness="1" />
            <Border CornerRadius="0,0,0,0" Grid.ColumnSpan="2" Margin="1,1,1,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF919191" Offset="1"/>
                        <GradientStop Color="White"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="등록된 사용자 리스트" Margin="5,1,0,0" FontWeight="Bold" Foreground="Black" FontSize="12" VerticalAlignment="Center"/>
            </Border>

            <Grid Name="grduserlist" Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.ColumnSpan="4" Background="#AADDDDDD" Margin="1, 0, 0, 0"/>

                <TextBlock HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5" FontSize="14">변경 가능 사용자</TextBlock>
                <TextBlock HorizontalAlignment="Center" FontWeight="Bold" VerticalAlignment="Bottom" Margin="5" Grid.Column="2" FontSize="14">변경 불가능 사용자</TextBlock>

                <Border Grid.Row="1" Grid.Column="0" Margin="0,2,17,0" Background="DarkGray"  BorderBrush="#FF919191" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="17"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NameBorder"/>
                        <Border Grid.Column="1" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NumberBorder"/>
                        <Border Grid.Column="2" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="AuthorBorder"/>
                        <Border Grid.Column="1" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                        <Border Grid.Column="2" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                        <TextBlock Grid.Column="0" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >이 름</TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >사 번</TextBlock>
                        <TextBlock Grid.Column="2" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >권 한</TextBlock>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Margin="0,2,17,0" Background="DarkGray"  BorderBrush="#FF919191" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="17"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NameBorder2"/>
                        <Border Grid.Column="1" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="NumberBorder2"/>
                        <Border Grid.Column="2" Background="DarkGray" BorderBrush="DarkGray" BorderThickness="1" Name="AuthorBorder2"/>
                        <Border Grid.Column="1" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                        <Border Grid.Column="2" HorizontalAlignment="Left" BorderBrush="#919191" BorderThickness="1"/>
                        <TextBlock Grid.Column="0" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >이 름</TextBlock>
                        <TextBlock Grid.Column="1" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >사 번</TextBlock>
                        <TextBlock Grid.Column="2" FontSize="12" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" >권 한</TextBlock>
                    </Grid>
                </Border>
                <ScrollViewer Name="svableGroup"  Grid.Row="2" VerticalScrollBarVisibility="Visible">
                    <ListBox x:Name="lbableGroup"  SelectionMode="Extended" >
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding ElementName=NameBorder, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="{Binding ElementName=NumberBorder, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="{Binding ElementName=AuthorBorder, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="17"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Path=Name, Mode=TwoWay}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Path=BusinessNumber, Mode=TwoWay}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Path=Author, Mode=TwoWay}" TextAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <ScrollViewer Name="svdisableGroup"  Grid.Row="2" Grid.Column="2">
                    <ListBox x:Name="lbdisableGroup" SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding ElementName=NameBorder2, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="{Binding ElementName=NumberBorder2, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="{Binding ElementName=AuthorBorder2, Path=ActualWidth}"/>
                                        <ColumnDefinition Width="17"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Path=Name, Mode=TwoWay}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Path=BusinessNumber, Mode=TwoWay}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Path=Author, Mode=TwoWay}" TextAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Width="55" Height="27" FontSize="12" Name="btnSendLeft">
                        <Image Source="/HDSInspector;component/Images/blackPrev.png" />
                    </Button>
                    <Button Width="55" Height="27" Margin="0, 3" Name="btnSendRight" FontSize="12">
                        <Image Source="/HDSInspector;component/Images/blackNext.png" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="3" HorizontalAlignment="Left" Margin="5">
                    <Button Width="70" Height="27" FontSize="12" Name="btnSelectAll">전체 선택</Button>
                    <Button Width="70" Height="27" Margin="0, 3" Name="btnUnSelectAll" FontSize="12">전체 취소</Button>
                    <Border Width="70" HorizontalAlignment="Left" BorderThickness="5"/>
                    <Border Width="70" HorizontalAlignment="Left" BorderBrush="#FF979797" BorderThickness="3"/>
                    <Border Width="70" HorizontalAlignment="Left" BorderThickness="5"/>
                    <Button Width="70" Height="27" Margin="0, 3" Name="btnAddUser" FontSize="12">신규 등록</Button>
                    <Button Width="70" Height="27" Margin="0, 3" Name="btnDeleteUser" FontSize="12">제 거</Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
