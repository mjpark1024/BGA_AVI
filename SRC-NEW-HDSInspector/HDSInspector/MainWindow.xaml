<Window x:Class="HDSInspector.MainWindow"
        xmlns:HDSInspector="clr-namespace:HDSInspector"
        xmlns:DCS="clr-namespace:DCS;assembly=DCS"
        xmlns:Sub="clr-namespace:HDSInspector.SubControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:my="clr-namespace:HDSInspector"
        xmlns:igs="clr-namespace:IGS;assembly=IGS_Client"
        xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
        mc:Ignorable="d"
        Icon="Images/icons8-machine-learning-100.ico"
        WindowStyle="ThreeDBorderWindow" WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        HorizontalAlignment="Center" VerticalAlignment="Center"
        d:DesignHeight="1080" d:DesignWidth="1920" WindowState="Maximized"
        Title="BGA AVI HDS Inspector v4.0.1 ICS, 불량이 없어도 Json생성 (26.04.24) [Gen2.5]">
    
    <Window.Resources>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Name="pnlMain">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="640"/>
            <ColumnDefinition />
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="1" Margin="0,1,2,1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition />
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="5"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Grid.ColumnSpan="6" CornerRadius="3,3,0,0" Background="Silver"/>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" FontWeight="Bold" Text="전산 정보"/>
                <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="Bold" Text="서버 연결 상태 : "/>

                <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="Green" FontWeight="Bold" Text="ON" Name="tbServerOn" Visibility="Hidden"/>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="OrangeRed" FontWeight="Bold" Text="OFF" Name="tbServerOff" Visibility="Visible"/>

                <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="연결 재시도" Name="btnServerRetry">
                    <Image Source="/HDSInspector;component/Images/small_refresh.png" Width="18" Height="20"/>
                </Button>
            </Grid>
            
            <igs:POPStateCtrl_Horizontal Grid.Row="1" x:Name="popStateCtrl"/>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition />
            </Grid.RowDefinitions>

            <my:MainToolBar x:Name="MainToolBarCtrl"/>

            <Grid Grid.Row="1" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="1" BorderThickness="0" Background="Gray" Name="btnResetTimer" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold" Text="Time Reset"/>
                </Button>
                
                <Border Grid.Column="1" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>
                <Border Grid.Column="3" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>
                <Border Grid.Column="5" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>
                <Border Grid.Column="7" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>
                <Border Grid.Column="9" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>
                <Border Grid.Column="11" Grid.ColumnSpan="2" CornerRadius="5" BorderThickness="1" BorderBrush="LightGray" Margin="1,0"/>

                <Border Grid.Column="1" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>
                <Border Grid.Column="3" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>
                <Border Grid.Column="5" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>
                <Border Grid.Column="7" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>
                <Border Grid.Column="9" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>
                <Border Grid.Column="11" CornerRadius="5,0,0,5" Background="LightGray" Margin="1,0,0,0"/>

                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="CA면 현재"/>
                <TextBlock Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="CA면 누적"/>
                <TextBlock Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="BA면 현재"/>
                <TextBlock Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="BA면 누적"/>
                <TextBlock Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="마킹 현재"/>
                <TextBlock Grid.Column="11" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Text="마킹 누적"/>

                <Label Name="lblCACycle" Grid.Column="2" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
                <Label Name="lblCAAverg" Grid.Column="4" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
                <Label Name="lblBACycle" Grid.Column="6" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
                <Label Name="lblBAAverg" Grid.Column="8" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
                <Label Name="lblLMCycle" Grid.Column="10" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
                <Label Name="lblLMAverg" Grid.Column="12" Content="00.00" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-2,0,0"/>
            </Grid>
        </Grid>

        <HDSInspector:InspectionMonitoring x:Name="InspectionMonitoringCtrl" Grid.Row="1"  Grid.ColumnSpan="4"/>
        <HDSInspector:ConBadWarning x:Name="conbad" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Width="1250" Height="650" Visibility="Hidden"></HDSInspector:ConBadWarning>
        <Sub:ReInspect x:Name="EndInspect" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Right" Width="1250" Height="350" Visibility="Hidden"></Sub:ReInspect>
    </Grid>
</Window>
