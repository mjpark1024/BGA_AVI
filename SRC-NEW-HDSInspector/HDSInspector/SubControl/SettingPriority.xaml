<UserControl x:Class="HDSInspector.SubControl.SettingPriority"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HDSInspector.SubControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>          
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.ColumnSpan="12" >
            <Border Background="#e8e9ea"></Border>
            <Label VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="15" FontWeight="Bold">검사 우선순위 설정(낮은 값 우선)</Label>            
        </Grid>
        <Grid Grid.Row="1" Grid.ColumnSpan="12" x:Name="GridPriority"></Grid>                
    </Grid>
</UserControl>
