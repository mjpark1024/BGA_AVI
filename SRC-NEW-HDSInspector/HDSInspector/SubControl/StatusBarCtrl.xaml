<UserControl x:Class="HDSInspector.StatusBarCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="30" d:DesignWidth="1600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="1.6*"/>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" FontFamily="Arial" Foreground="#232323" Text="MODEL"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="2" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" FontFamily="Arial" Foreground="#232323" Text="LOT"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="4" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="20" FontFamily="Arial" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="#232323" Text="검사자"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="6" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="16" FontFamily="Arial" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="#232323" Text="TACT TIME"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="8" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="16" FontFamily="Arial" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="#232323" Text="시작시간"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="10" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock FontSize="16" FontFamily="Arial" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="#232323" Text="경과시간"/>
        </Border>

        <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0, 0, 1, 1" Margin="0,2,0,-2">
            <TextBlock FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="Black" FontFamily="Arial" Text="-" Name="txtModel"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="3" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <TextBlock FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="Black" FontFamily="Arial" Text="-" Name="txtLot"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="5" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <TextBlock FontSize="16" VerticalAlignment="Center"  HorizontalAlignment="Center" FontWeight="UltraBold" Foreground="Black" FontFamily="Arial" Text="-" Name="txtOperator"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="7" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Center" >
                <TextBlock FontSize="16" FontWeight="UltraBold" VerticalAlignment="Center" Foreground="Black" Margin="5,0,0,0" Text="-" FontFamily="Arial" Name="txtTackTime"/>
                <TextBlock FontSize="16" FontWeight="UltraBold" VerticalAlignment="Center" Foreground="Black" Margin="3,0,10,0" FontFamily="Arial" Text="초/Strip"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="9" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Center" >
                <TextBlock FontSize="16" FontWeight="UltraBold" VerticalAlignment="Center" Foreground="Black" Margin="5,0,0,0" Text="12일12:12:12" FontFamily="Arial" Name="txtStratTime"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="11" BorderBrush="Black" BorderThickness="0, 0, 1, 1">
            <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Center" >
                <TextBlock FontSize="16" FontWeight="UltraBold" VerticalAlignment="Center" Foreground="Black" Margin="5,0,0,0" Text="12시간12분12초" FontFamily="Arial" Name="txtRunTime"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="12" BorderBrush="Black" BorderThickness="0, 0, 0, 1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" MappingMode="RelativeToBoundingBox" StartPoint="0.5,0">
                    <GradientStop Color="#FFFDFDFD" Offset="0"/>
                    <GradientStop Color="#FFA7A7A7" Offset="0.700"/>
                    <GradientStop Color="#FFDADADA" Offset="0.350"/>
                    <GradientStop Color="#FFC4C4C4" Offset="0.500"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Center">
                <CheckBox Name="chkVerify" VerticalAlignment="Center"/>
                <TextBlock FontSize="14"  FontFamily="Franklin Gothic" FontWeight="Bold" VerticalAlignment="Center" Foreground="Black" Margin="5,0,0,0" Text="Verify 수행" Name="txtVerify"/>
            </StackPanel>
        </Border>        
    </Grid>
</UserControl>
