<UserControl x:Class="HDSInspector.SubControl.LotStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="500">
    <Grid>
        <Border Grid.Row="0" Grid.ColumnSpan="10" Name="BorderFrame" Height="32">
            <Border BorderBrush="Gray" BorderThickness="6" CornerRadius="4" Margin="2,0,2,0"/>
        </Border>
        <Grid Height="18" Margin="10,0,10,0" Grid.ColumnSpan="2" Name="StripStackPanel" HorizontalAlignment="Stretch"/>
        <TextBlock Foreground="Black" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" Opacity="0.9">로트내 불량 Strip 분포</TextBlock>
    </Grid>
</UserControl>
