<Window xmlns:my="clr-namespace:HDSInspector.SubControl"  xmlns:my1="clr-namespace:HDSInspector"  x:Class="HDSInspector.InspectResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"                
        xmlns:datavis="clr-namespace:System.Windows.Controls.DataVisualization;assembly=System.Windows.Controls.DataVisualization.Toolkit"
        xmlns:chartingToolkit="clr-namespace:System.Windows.Controls.DataVisualization.Charting;assembly=System.Windows.Controls.DataVisualization.Toolkit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        Title="검사 결과" Height="1044" Width="1700"
        WindowStartupLocation="CenterScreen" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        
        <Grid Margin="2,2,5,6" Name="MainBar"  DataContext="{Binding}" Grid.ColumnSpan="2">
            <Border BorderBrush="#FF919191" Margin="1,2,1,2" CornerRadius="5">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.5"/>
                </Border.Effect>
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#4c7eb6" Offset="0.250"/>
                        <GradientStop Color="#195aa2" Offset="0.750"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="EAV001 장비" FontSize="22" Margin="20,3,0,4" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Name="txtEquipName"/>
                <TextBlock Text="{Binding Path=GroupName}" FontSize="20" Margin="30,12,0,2" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Path=ModelName}" FontSize="20" Margin="20,12,0,2" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Path=LotNo}" FontSize="20" Margin="20,12,0,2" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Path=Operator}" FontSize="20" Margin="30,12,0,2" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,2">
                <TextBlock Text="시작시간" HorizontalAlignment="Center" Margin="0,10,0,0"  FontSize="15" FontWeight="Bold" Foreground="#E0E0E0"/>
                <TextBlock Text="{Binding Path=StartTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" HorizontalAlignment="Center" Margin="10,15,0,0"  FontSize="12" FontWeight="Bold" Foreground="#E0E0E0"/>
                <TextBlock Text="종료시간" HorizontalAlignment="Center" Margin="30,10,0,0"  FontSize="15" FontWeight="Bold" Foreground="#E0E0E0"/>
                <TextBlock Text="{Binding Path=EndTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" HorizontalAlignment="Center" Margin="10,15,0,0"  FontSize="12" FontWeight="Bold" Foreground="#E0E0E0"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="120*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Silver" BorderThickness="1" Grid.Column="0" Height="Auto" HorizontalAlignment="Stretch" Margin="0" VerticalAlignment="Stretch" Width="Auto" >
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.3">
                        <GradientStop Color="#77444444" Offset="1"/>
                        <GradientStop Color="White" Offset="0.3"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border BorderBrush="Silver" BorderThickness="1" Grid.Column="1" Grid.ColumnSpan="2" Height="Auto" HorizontalAlignment="Stretch" Margin="0" VerticalAlignment="Stretch" Width="Auto" >
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.3">
                        <GradientStop Color="#77444444" Offset="1"/>
                        <GradientStop Color="White" Offset="0.3"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border BorderBrush="Silver" BorderThickness="1" Grid.Column="3" Grid.ColumnSpan="3" Height="Auto" HorizontalAlignment="Stretch" Margin="0" VerticalAlignment="Stretch" Width="Auto" >
                <Border.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0" Opacity="0.3">
                        <GradientStop Color="#77444444" Offset="1"/>
                        <GradientStop Color="White" Offset="0.3"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <RadioButton FontSize="20" Content="기준+불량" Height="35" Name="rbAllImage" Width="136" VerticalAlignment="Top" Margin="0,20,0,10" Grid.Column="0" GroupName="a" HorizontalAlignment ="Center"/>
            <RadioButton FontSize="20" Content="불량" Height="35" Name="rbBadImage" Width="136" VerticalAlignment="Top" Margin="0,50,0,10" Grid.Column="0" GroupName="a" HorizontalAlignment ="Center"/>

            <RadioButton FontSize="16" Content="전체이미지" Height="25" Name="rbAllCamera" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-70,0,0" Grid.Column="1" Grid.ColumnSpan="2" GroupName="b"/>
            <RadioButton FontSize="16" Content="BA외관1" Height="25" Name="rbBotSur1" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-20,0,0" Grid.Column="1" GroupName="b"/>
            <RadioButton FontSize="16" Content="BA외관2" Height="25" Name="rbBotSur2" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,30,0,0" Grid.Column="1" GroupName="b"/>
            
            <RadioButton FontSize="16" Content="본드패드1" Height="25" Name="rbBondPad1" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,80,0,0" Grid.Column="1" GroupName="b"/>
            
            <RadioButton FontSize="16" Content="본드패드2" Height="25" Name="rbBondPad2" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-20,0,0" Grid.Column="2" GroupName="b"/>
            
            <RadioButton FontSize="16" Content="CA외관1" Height="25" Name="rbTopSur1" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,30,0,0" Grid.Column="2" GroupName="b"/>
            <RadioButton FontSize="16" Content="CA외관2" Height="25" Name="rbTopSur2" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,80,0,0" Grid.Column="2" GroupName="b"/>

            <RadioButton FontSize="15" Content="전체" Height="23" Name="rbAll" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-80,0,0" Grid.Column="3" GroupName="c"/>
            <RadioButton FontSize="15" Content="원소재" Height="23" Name="rbRaw" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-30,0,0" Grid.Column="3" GroupName="c"/>
            <RadioButton FontSize="15" Content="본드패드" Height="23" Name="rbBP" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,20,0,0" Grid.Column="3" GroupName="c"/>
            <RadioButton FontSize="15" Content="Open" Height="23" Name="rbOpen" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,70,0,0" Grid.Column="3" GroupName="c"/>
            <RadioButton FontSize="15" Content="Short" Height="23" Name="rbShort" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-80,0,0" Grid.Column="4" GroupName="c"/>
            <RadioButton FontSize="15" Content="Ball" Height="23" Name="rbBall" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-30,0,0" Grid.Column="4" GroupName="c"/>
            <RadioButton FontSize="15" Content="PSR핀홀" Height="23" Name="rbNPSR" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,20,0,0" Grid.Column="4" GroupName="c"/>
            <RadioButton FontSize="15" Content="PSR이물질" Height="23" Name="rbPSR" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,70,0,0" Grid.Column="4" GroupName="c"/>
            <RadioButton FontSize="15" Content="Burr" Height="23" Name="rbBurr" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-80,0,0" Grid.Column="5" GroupName="c"/>
            <RadioButton FontSize="15" Content="Crack" Height="23" Name="rbCrack" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,-30,0,0" Grid.Column="5" GroupName="c"/>
            <RadioButton FontSize="15" Content="VentHole" Height="23" Name="rbVH" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,20,0,0" Grid.Column="5" GroupName="c"/>
            <RadioButton FontSize="15" Content="Align" Height="23" Name="rbAlign" Width="96" VerticalAlignment="Center" HorizontalAlignment ="Center" Margin="0,70,0,0" Grid.Column="5" GroupName="c"/>
            <Button Grid.Column="6" Content="적 용" Name="btnApply" FontWeight="Bold" FontSize="15"  Margin="5"/>
            <Grid Grid.Column="8" Grid.Row="0" HorizontalAlignment="Stretch" Margin="5,0,0,0"  VerticalAlignment="Stretch" Width="Auto" Background="#4c7eb6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Button Height="50" Name="btnPrev10" Width="40" FontWeight="Bold" FontSize="15" HorizontalAlignment="Left" Margin="5,0,0,8" VerticalAlignment="Bottom" Grid.Row="6">
                    <Image Source="/HDSInspector;component/Images/blackDoublePrev.png" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Width="25" Margin="0, 0, 0, 0"/>
                </Button>
                <Button Height="50" Name="btnNext10" Width="40" FontWeight="Bold" HorizontalAlignment="Right"  Margin="0,0,5,8" VerticalAlignment="Bottom" Grid.Row="6">
                    <Image Source="/HDSInspector;component/Images/blackDoubleNext.png" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Width="25" Margin="0,0, 0, 0"/>
                </Button>
                <Button Height="50" Name="btnPrev" Width="40" FontWeight="Bold" FontSize="15" HorizontalAlignment="Left" Margin="48,0,0,8" VerticalAlignment="Bottom" Grid.Row="6">
                    <Image Source="/HDSInspector;component/Images/blackPrev.png" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Width="25" Margin="0, 0, 0, 0"/>
                </Button>
                <Button Height="50" Name="btnNext" Width="40" FontWeight="Bold" HorizontalAlignment="Right"  Margin="0,0,48,8" VerticalAlignment="Bottom" Grid.Row="6">
                    <Image Source="/HDSInspector;component/Images/blackNext.png" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Width="25" Margin="0, 0, 0, 0"/>
                </Button>
                <Slider Grid.Row="6" Name="sldPage" Interval="1" Value="0" VerticalAlignment="Bottom" Style="{DynamicResource SimpleSlider}" Margin="0,0,2,25" Width="300"/>
                <TextBlock Grid.Row="6" HorizontalAlignment="Center" FontSize="25" Height="40" VerticalAlignment="Top"  FontWeight="Bold" Name="tbPage" Foreground="White" Text="Page"/>
            </Grid>

            
        </Grid>

        <Grid Name="ResultGraphGrid" Grid.Row="1" Grid.RowSpan="2">

            <Grid.RowDefinitions>
                <RowDefinition Height="240"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="180"/>
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Margin="0" Grid.Column="0" Grid.Row="1">
                <Grid Grid.Column="1" Grid.RowSpan="10" Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.ColumnSpan="1" Background="White" BorderThickness="3,3,0,1" CornerRadius="5,0,0,0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="1" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="3" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="4" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,3" CornerRadius="0,0,0,5" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1" Background="White" BorderThickness="0,3,0,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="1" Grid.Column="2"  Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="2" Grid.Column="2"  Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="3" Grid.Column="2"  Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="4" Grid.Column="2"  Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,3" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="0" Grid.Column="1" Background="White" BorderThickness="0,3,0,1" CornerRadius="0,0,0,0" BorderBrush="#4c7eb6"/>
                    <Border Grid.Row="1" Grid.Column="1" Background="WhiteSmoke" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="2" Grid.Column="1" Background="WhiteSmoke" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="3" Grid.Column="1" Background="WhiteSmoke" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="4" Grid.Column="1" Background="WhiteSmoke" BorderThickness="1,1,1,3" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="0" Grid.Column="3" Background="White" BorderThickness="0,3,3,1" CornerRadius="0,5,0,0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="1" Grid.Column="3" Background="WhiteSmoke" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="2" Grid.Column="3" Background="WhiteSmoke" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="3" Grid.Column="3" Background="WhiteSmoke" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                    <Border Grid.Row="4" Grid.Column="3" Background="WhiteSmoke" BorderThickness="1,1,3,3" CornerRadius="0,0,5,0" BorderBrush="#4c7eb6" />

                    <TextBlock FontSize="22" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold">검  사    정  보</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">투입스트립</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">완성스트립</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">전체 Unit</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="0" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" >불량 Unit</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">양품스트립</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="2" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">불량스트립</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="2" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">폐기스트립</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="2" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold">수율</TextBlock>
                    <TextBlock FontSize="20" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=InspectStrip}"/>
                    <TextBlock FontSize="20" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=TotalStrip}"/>
                    <TextBlock FontSize="20" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=TotalUnits}"/>
                    <TextBlock FontSize="20" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=BadUnits}"/>
                    <TextBlock FontSize="20" Grid.Column="3" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=GoodStrip}"/>
                    <TextBlock FontSize="20" Grid.Column="3" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=BadStrip}"/>
                    <TextBlock FontSize="20" Grid.Column="3" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=FailStrip}"/>
                    <TextBlock FontSize="20" Grid.Column="3" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Path=Yield, StringFormat=00.00}"/>

                </Grid>


            </Grid>
            <Grid Grid.Row="2" Grid.Column="0" Grid.RowSpan="1" Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,3,1,1" CornerRadius="5,0,0,0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="1" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="3" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="4" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="5" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="3,1,1,3" CornerRadius="0,0,0,5" BorderBrush="#4c7eb6" />
                <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,3,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="1" Background="#FFF6EEEE" BorderThickness="1,1,1,3" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="0" Grid.Column="1" Background="White" BorderThickness="1,3,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="1" Grid.Column="1" Background="White" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="2" Grid.Column="1" Background="White" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="3" Grid.Column="1" Background="White" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="4" Grid.Column="1" Background="White" BorderThickness="1,1,1,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="5" Grid.Column="1" Background="White" BorderThickness="1,1,1,3" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="0" Grid.Column="3" Background="White" BorderThickness="1,3,3,1" CornerRadius="0,5,0,0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="1" Grid.Column="3" Background="White" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="2" Grid.Column="3" Background="White" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="3" Grid.Column="3" Background="White" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="4" Grid.Column="3" Background="White" BorderThickness="1,1,3,1" CornerRadius="0" BorderBrush="#4c7eb6" />
                <Border Grid.Row="5" Grid.Column="3" Background="White" BorderThickness="1,1,3,3" CornerRadius="0,0,5,0" BorderBrush="#4c7eb6" />
                <Label Grid.Row="5" Grid.Column="2" Content="Align" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Foreground="Black" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="0" Content="원소재" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1" Foreground="Olive" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="2" Content="Open" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Red" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="3" Content="Short" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Blue" FontFamily="HY부활L" FontWeight="Bold" Background="{x:Null}" HorizontalAlignment="Right"/>
                <Label Grid.Row="1" Content="BondPad" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Goldenrod" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="4" Grid.Column="0" Content="Ball" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="SkyBlue" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="0" Grid.Column="2" Content="PSR핀홀" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Fuchsia" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="1" Grid.Column="2" Content="PSR이물질" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="Green" FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="2" Grid.Column="2" Content="Punch Burr" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="IndianRed"  FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
                <Label Grid.Row="3" Grid.Column="2" Content="Core Crack" FontSize="15" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"  Margin="1" Foreground="LightSteelBlue"  FontFamily="HY부활L" FontWeight="Bold" HorizontalAlignment="Right"/>
