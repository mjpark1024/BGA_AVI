<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HDSInspector" x:Class="HDSInspector.PLCSetupWindow"
        Title="PLCSetupWindow" Height="350" Width="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Column="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Margin="3" Name="btnStart">검사시작</Button>
        </Grid>
        <local:LedLamp Grid.Column="0" x:Name="lmpManual" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="2" x:Name="lmpConfig" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="4" x:Name="lmpAuto" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="0" VerticalContentAlignment="Center" FontSize="15" Margin="2">수동모드</Label>
        <Label Grid.Column="3" Grid.Row="0" VerticalContentAlignment="Center" FontSize="15" Margin="2">설정모드</Label>
        <Label Grid.Column="5" Grid.Row="0" VerticalContentAlignment="Center" FontSize="15" Margin="2">자동모드</Label>
        <local:LedLamp Grid.Column="0" Grid.Row="1"  x:Name="lmpRI11" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="2" Grid.Row="1"  x:Name="lmpRI12" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" FontSize="15" Margin="2">검사요구 1-1</Label>
        <Label Grid.Column="3" Grid.Row="1" VerticalContentAlignment="Center" FontSize="15" Margin="2">검사요구 1-2</Label>
        <Label Grid.Column="4" Grid.Row="1" VerticalContentAlignment="Center" FontSize="15" Margin="2">ID</Label>
        <Label Grid.Column="5" Grid.Row="1" VerticalContentAlignment="Center" FontSize="15" Margin="2" Name="lblID1">0</Label>
        <local:LedLamp Grid.Column="0" Grid.Row="2"  x:Name="lmpRI21" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="2" Grid.Row="2"  x:Name="lmpRI22" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" FontSize="15" Margin="2">검사요구 2-1</Label>
        <Label Grid.Column="3" Grid.Row="2" VerticalContentAlignment="Center" FontSize="15" Margin="2">검사요구 2-2</Label>
        <Label Grid.Column="4" Grid.Row="2" VerticalContentAlignment="Center" FontSize="15" Margin="2">ID</Label>
        <Label Grid.Column="5" Grid.Row="2" VerticalContentAlignment="Center" FontSize="15" Margin="2" Name="lblID2">0</Label>
        <local:LedLamp Grid.Column="0" Grid.Row="3"  x:Name="lmpRR" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="3" VerticalContentAlignment="Center" FontSize="15" Margin="2">결과 요구</Label>
        <TextBox Grid.Row="3" Grid.Column="3" Margin="3">1</TextBox>
        <Button Name="btnResult" Grid.Column="7" Grid.Row="3" Margin="5">결과전송</Button>
        <local:LedLamp Grid.Column="0" Grid.Row="4"  x:Name="lmpRA11" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="2" Grid.Row="4"  x:Name="lmpRA12" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="4" VerticalContentAlignment="Center" FontSize="15" Margin="2">Align요구 11</Label>
        <Label Grid.Column="3" Grid.Row="4" VerticalContentAlignment="Center" FontSize="15" Margin="2">Align요구 12</Label>
        <local:LedLamp Grid.Column="0" Grid.Row="5"  x:Name="lmpRA21" Width="30"></local:LedLamp>
        <local:LedLamp Grid.Column="2" Grid.Row="5"  x:Name="lmpRA22" Width="30"></local:LedLamp>
        <Label Grid.Column="1" Grid.Row="5" VerticalContentAlignment="Center" FontSize="15" Margin="2">Align요구 21</Label>
        <Label Grid.Column="3" Grid.Row="5" VerticalContentAlignment="Center" FontSize="15" Margin="2">Align요구 22</Label>
        <Label Grid.Column="5" Grid.Row="3" VerticalContentAlignment="Center" FontSize="15" Margin="2" Name="lblResID">0</Label>
        <Label Grid.Column="6" Grid.Row="4" VerticalContentAlignment="Center" FontSize="15" Margin="2" Name="lblLBID1">0</Label>
        <Label Grid.Column="6" Grid.Row="5" VerticalContentAlignment="Center" FontSize="15" Margin="2" Name="lblLBID2">0</Label>
        <Button Name="btnPassAlign" Grid.Column="7" Grid.Row="4" Margin="5">PASS</Button>
        <local:LedLamp Grid.Column="4" Grid.Row="4"  x:Name="lmpRL1" Width="30"></local:LedLamp>
        <Label Grid.Column="5" Grid.Row="4" VerticalContentAlignment="Center" FontSize="15" Margin="2">Laser요구1 </Label>
        <local:LedLamp Grid.Column="4" Grid.Row="5"  x:Name="lmpRL2" Width="30"></local:LedLamp>
        <Label Grid.Column="5" Grid.Row="5" VerticalContentAlignment="Center" FontSize="15" Margin="2">Laser요구2</Label>
        <Button Name="btnPassLaser" Grid.Column="7" Grid.Row="5" Margin="2,10,8,0">PASS</Button>
        <Label Grid.Row="8" Grid.Column="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">주소</Label>
        <Label Grid.Row="8" Grid.Column="2" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">값</Label>
        <TextBox Grid.Row="8" Grid.Column="1" Margin="3" Name="txtAdd"></TextBox>
        <TextBox Grid.Row="8" Grid.Column="3" Margin="3" Name="txtVal"></TextBox>
        <Grid Grid.Row="8" Grid.Column="4" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Name="btnSet" FontSize="13" Margin="2">Set</Button>
            <Button Grid.Column="1" Name="btnGet" FontSize="13" Margin="2">Get</Button>
        </Grid>
    </Grid>
</Window>
