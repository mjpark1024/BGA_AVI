<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HDSInspector" x:Class="HDSInspector.ConBadWarning" 
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1250">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FFFF7E7E" Offset="0.002"/>
                <GradientStop Color="#FFFF7878" Offset="1"/>
                <GradientStop Color="#FFFF0101" Offset="0.51"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Label Grid.ColumnSpan="4" FontSize="25" Margin="15,5,5,5" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Content="설정된 누적 Unit불량 수 보다 많은수의 Strip이 발생 되었습니다."/>
        <local:BadMap x:Name="map" Margin="15,5" Grid.Row="1" Grid.ColumnSpan="4"/>
        <Label Content="검사를 정지 하시려면" Grid.Row="2" Grid.ColumnSpan="2" FontSize="25" Margin="15,5,5,5" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"></Label>
        <Label Content="검사를 계속 진행 하시려면" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" FontSize="25" Margin="15,5,5,5" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"></Label>
        <Button Name="btnstop"  Grid.Row="3" Grid.ColumnSpan="2" Width="150" Margin="15" FontSize="15" FontWeight="Bold">검사 정지</Button>
        <Button Name="btnContinue"  Grid.Row="3" Grid.ColumnSpan="2" Grid.Column="2" Width="150" Margin="15" FontSize="15" FontWeight="Bold">검사 진행</Button>
    </Grid>
</UserControl>
