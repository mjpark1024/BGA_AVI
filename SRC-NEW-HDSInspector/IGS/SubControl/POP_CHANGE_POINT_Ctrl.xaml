<UserControl x:Class="IGS.SubControl.POP_CHANGE_POINT_Ctrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IGS.SubControl"
             mc:Ignorable="d" 
             d:DesignHeight="185" d:DesignWidth="700">
    
    <Grid>
        <Viewbox Stretch="Uniform">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="700"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="3" Width="700" BorderThickness="1" BorderBrush="Silver" Background="White"/>
                <Border Grid.Row="0" Background="Black" BorderBrush="Gray" BorderThickness="1">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="White" FontSize="17" FontWeight="Bold" Text="변경점 조회"/>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="65"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="변경점분류"/>
                    </Border>
                    <Border Grid.Column="1" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="제목"/>
                    </Border>
                    <Border Grid.Column="2" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="제품코드"/>
                    </Border>
                    <Border Grid.Column="3" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="공정코드"/>
                    </Border>
                    <Border Grid.Column="4" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="설비코드"/>
                    </Border>
                    <Border Grid.Column="5" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="신고일자"/>
                    </Border>
                </Grid>

                <ScrollViewer Grid.Row="2" x:Name="svInfo" Background="Transparent" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True">
                    <ListBox x:Name="lbInfo" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="Silver"/>
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="Auto" Margin="-5,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="65"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding chg_div}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding chg_title}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="14" TextWrapping="WrapWithOverflow"/>
                                    <TextBlock Grid.Column="2" Text="{Binding item_cd}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="3" Text="{Binding op_cd}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="4" Text="{Binding eqpt_cd}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="5" Text="{Binding reg_dt}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
