<UserControl x:Class="IGS.SubControl.POP_MODEL_HISTORY_Ctrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IGS.SubControl"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="450">

    <Grid>
        <Viewbox Stretch="Uniform">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="115"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="450"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="3" Width="450" BorderThickness="1" BorderBrush="Silver" Background="White"/>
                <Border Grid.Row="0" Background="Black" BorderBrush="Gray" BorderThickness="1">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="White" FontSize="17" FontWeight="Bold" Text="동일 모델 최근 가동 이력 조회"/>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="No."/>
                    </Border>
                    <Border Grid.Column="1" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="모델 코드"/>
                    </Border>
                    <Border Grid.Column="2" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="설비 코드"/>
                    </Border>
                    <Border Grid.Column="3" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="가동 일자"/>
                    </Border>
                </Grid>

                <Border Grid.Row="2" BorderBrush="Silver" BorderThickness="1"/>
                <ScrollViewer Grid.Row="2" x:Name="svInfo" Margin="1" Background="Transparent" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True">
                    <ListBox x:Name="lbInfo" ItemsSource="{Binding}" IsSynchronizedWithCurrentItem="True">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="Silver"/>
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="Auto" Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding idx}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding model_code}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="2" Text="{Binding mc_code}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="3" Text="{Binding prod_dt}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" Margin="45,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <Border Grid.Row="2" Background="White" BorderBrush="Silver" BorderThickness="1" Name="bdFail" Visibility="Hidden">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="13" Text="MES 조회에 실패하였습니다. 기존 POP 프로그램을 조회바랍니다."/>
                </Border>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
