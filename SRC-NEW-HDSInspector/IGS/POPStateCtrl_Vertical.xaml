<UserControl x:Class="IGS.POPStateCtrl_Vertical"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IGS"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="100">

    <Grid Background="White">
        <Viewbox Stretch="Fill">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" CornerRadius="5,5,0,0" Background="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Text="설비 코드"/>
                </Border>
                <Border Grid.Row="2" Background="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Text="설비 상태"/>
                </Border>
                <Border Grid.Row="4" Background="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Text="오더 번호"/>
                </Border>
                <Border Grid.Row="6" Background="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="11" Text="사용자"/>
                </Border>

                <Border Grid.Row="1" BorderThickness="1,0" BorderBrush="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Name="tbMachine"/>
                </Border>
                <Border Grid.Row="3" BorderThickness="1,0" BorderBrush="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Name="tbState" TextWrapping="WrapWithOverflow"/>
                </Border>
                <Border Grid.Row="5" BorderThickness="1,0" BorderBrush="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Name="tbLot"/>
                </Border>
                <Border Grid.Row="7" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5" BorderBrush="Silver">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Name="tbUserName"/>
                </Border>

                <Button Grid.Row="0" Width="20" VerticalAlignment="Center" HorizontalAlignment="Right" Background="Transparent" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand" Name="btnRefresh" ToolTip="새로고침">
                    <Image Source="./Images/refresh.png" Width="15"/>
                </Button>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
