<Window x:Class="IGS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IGS"
        mc:Ignorable="d"
        Icon="mts_icon.ico"
        WindowStartupLocation="CenterScreen"
        Title="IGS Client Tester" Height="350" Width="630">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <local:POPStateCtrl_Horizontal Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" x:Name="StateCtrl" Margin="1"/>
        <local:ReportMenuCtrl Grid.Row="2" Grid.Column="0" x:Name="ReportCtrl"/>
        <local:UserCtrl Grid.Row="2" Grid.Column="1" Margin="5,15" x:Name="userCtrl"/>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="15" Text="설비코드 변경"/>
            <TextBox Grid.Column="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="15" Width="80" Height="35" Name="tbMcCode"/>
            <Button Grid.Column="2" HorizontalAlignment="Left" Width="50" Height="35" Margin="5,0,0,0" FontSize="15" Content="적용" Name="btnChange"/>

            <Button Grid.Column="3" Width="80" Height="35" HorizontalAlignment="Left" Name="btnStart" Content="검사 시작"/>
            <Button Grid.Column="4" Width="80" Height="35" Margin="0,0,0,0" HorizontalAlignment="Left" Name="btnStop" Content="검사 정지"/>
            <Button Grid.Column="5" Width="80" Height="35" Margin="0,0,0,0" HorizontalAlignment="Left" Name="btnTest" Content="기타 TEST" Visibility="Visible"/>
        </Grid>
    </Grid>
</Window>
