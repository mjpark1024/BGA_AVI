<UserControl x:Class="IGS.UserCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IGS"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="230">
    
    <Grid Background="White">
        <Viewbox Stretch="Fill">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="110"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="Black" BorderBrush="Gray" BorderThickness="1" Name="bdTitle">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="White" FontSize="16" FontWeight="Bold" Text="사용자 정보"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BorderThickness="1,0,1,1" BorderBrush="Silver" Opacity="0.5"/>

                <Image Grid.Row="1" Grid.Column="0" Source="./Images/User.png" Margin="5"/>

                <Grid Grid.Row="1" Grid.Column="1" Name="grdCurUser" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition Height="10"/>
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Name="tbDeptName" FontSize="14"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Name="tbUserName" FontSize="14" FontWeight="Bold"/>
                        <TextBlock VerticalAlignment="Center" Name="tbPosName" FontSize="14" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Row="3" Width="100" Margin="2,4,5,4" HorizontalAlignment="Right" BorderThickness="0" Background="#FF102239" Cursor="Hand" Name="btnChange">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="14" Text="사용자 변경"/>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="1" Name="grdChange" Visibility="Hidden">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition Height="10"/>
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="사번 :"/>
                        <TextBox VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Width="60" Margin="3,5" FontSize="14" Name="tboxUserID"/>
                        <Button Width="40" Margin="2,5" BorderThickness="0" Background="#FF102239" Cursor="Hand" Name="btnSearch">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="14" Text="검색"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="14" Text="이름 :"/>
                        <TextBlock VerticalAlignment="Center" FontSize="14" Name="tbSearchName" Margin="3,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Width="60" Height="25" BorderThickness="0" Background="OrangeRed" Cursor="Hand" Name="btnOK">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="14" Text="변경"/>
                        </Button>
                        <Button Width="60" Height="25" BorderThickness="0" Background="DimGray" Cursor="Hand" Name="btnCancel" Margin="10,0,0,0">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="14" Text="취소"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>
