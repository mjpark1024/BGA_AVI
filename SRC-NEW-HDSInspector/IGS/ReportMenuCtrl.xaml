<UserControl x:Class="IGS.ReportMenuCtrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IGS"
             mc:Ignorable="d"              
             d:DesignHeight="240" d:DesignWidth="300">

    <Grid Background="White">
        <Viewbox Stretch="Fill">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnAttend" IsEnabled="True">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/attend2.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="출근"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="보고"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnLeave" IsEnabled="True">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/leave.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="퇴근"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="보고"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnExcept">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/except.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="비가동"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="보고"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="0" Grid.Row="1" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnStop">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/stop.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="중단"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="보고"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Grid.Row="1" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnComplete">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/complete.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="완료"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="보고"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Grid.Row="1" Margin="4,5" BorderThickness="1" BorderBrush="Silver" Background="White" Cursor="Hand" Name="btnLotSearch">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="5" Direction="310" Color="DarkGray" BlurRadius="4" Opacity="0.9"/>
                    </Button.Effect>
                    <StackPanel Orientation="Vertical">
                        <Image Source="./Images/search_color2.png" Width="55"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="LOT"/>
                        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="검색"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>