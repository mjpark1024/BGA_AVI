<Window x:Class="IGS.SubWindow.WARNING_POPUP_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sub="clr-namespace:IGS.SubControl"
        xmlns:local="clr-namespace:IGS.SubWindow"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Title="WARNING_POPUP_Window" Height="560" Width="940">
    
    <Grid Background="WhiteSmoke">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <sub:POP_WARNING_Ctrl Grid.Row="0" x:Name="warningCtrl"/>
        <sub:POP_CHANGE_POINT_Ctrl Grid.Row="1" x:Name="changeCtrl"/>

        <Button Grid.Row="2" HorizontalAlignment="Center" Width="150" Height="45" BorderThickness="0" Background="DimGray" Name="btnOK" Cursor="Hand">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="White" Text="확 인"/>
        </Button>
    </Grid>
</Window>
