<Window x:Class="IGS.SubWindow.POP_WARNING_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sub="clr-namespace:IGS.SubControl"
        xmlns:local="clr-namespace:IGS.SubWindow"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Title="WARNING / HOLDING" Height="185" Width="700">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        
        <sub:POP_WARNING_Ctrl Grid.Row="0" Grid.RowSpan="2" x:Name="warningCtrl"/>

        <Border Grid.Row="0" Background="Transparent" BorderThickness="0" Name="bdTitle"/>
        <Button Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Right" Width="80" Height="25" Margin="0,0,5,0" Background="DimGray"
                BorderThickness="0" Cursor="Hand" Name="btnOK">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="확인"/>
        </Button>
    </Grid>
</Window>
