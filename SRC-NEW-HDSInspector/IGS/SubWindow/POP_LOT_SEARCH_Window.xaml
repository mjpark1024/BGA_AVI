<Window x:Class="IGS.SubWindow.POP_LOT_SEARCH_Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sub="clr-namespace:IGS.SubControl"
        xmlns:local="clr-namespace:IGS.SubWindow"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="White"
        Topmost="True"
        Title="LOT 정보 검색" Height="640" Width="720">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="190"/>
            <RowDefinition Height="190"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition />
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="19" Text="검색 조건"/>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" BorderBrush="Silver" Background="SkyBlue">
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="19" Text="설비명"/>
            </Border>
            <Border Grid.Column="3" BorderThickness="1" BorderBrush="Silver" Background="SkyBlue">
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="19" Text="LOT"/>
            </Border>
            <Border Grid.Column="5" BorderThickness="1" BorderBrush="Silver" Background="SkyBlue">
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="19" Text="공정"/>
            </Border>

            <Border Grid.Column="0" Grid.ColumnSpan="8" BorderBrush="Silver" BorderThickness="1"/>
            <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="19" Name="tbMachine"/>
            <TextBox Grid.Column="4" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="5,3" FontSize="19" Name="tbLot">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <TextBox Grid.Column="6" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="5,3" FontSize="19" Name="tbOpcode">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button Grid.Column="7" BorderThickness="0" Margin="5,3" Background="#FF102239" Cursor="Hand" Name="btnSearch">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="19" FontWeight="Bold" Foreground="White" Text="검색"/>
            </Button>
        </Grid>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="Black" BorderBrush="Gray" BorderThickness="1">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="White" FontSize="17" FontWeight="Bold" Text="시작보고 가능 여부"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="결과"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="0" BorderThickness="1" BorderBrush="Silver" Background="#FFC2CADC">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="15" FontWeight="Bold" Text="사유"/>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BorderThickness="1" BorderBrush="Silver"/>
                <Border Grid.Row="2" Grid.Column="1" BorderThickness="1" BorderBrush="Silver"/>

                <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" FontWeight="Bold" FontSize="16" Name="tbStartCheckCode"/>
                <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0,0,0" FontSize="16" Name="tbStartCheckMsg" TextWrapping="Wrap"/>
            </Grid>
            
            <sub:POP_MODEL_HISTORY_Ctrl Grid.Column="1" x:Name="historyCtrl"/>
        </Grid>

        <sub:POP_WARNING_Ctrl Grid.Row="2" Margin="0" x:Name="warningCtrl"/>
        <sub:POP_CHANGE_POINT_Ctrl Grid.Row="3" Margin="0" x:Name="changeCtrl"/>
    </Grid>
</Window>
