<Window x:Class="ResultManagement.UserRegistration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UserRegistration" Height="450" Width="450" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Icon="{x:Null}" WindowStyle="ToolWindow">
    <Grid Margin="15,10,15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.6*"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="0.4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 0, 33" Background="LightGray" Height="2" Grid.ColumnSpan="4"/>
        <Border Grid.Row="0" VerticalAlignment="Bottom" Margin="3, 0, 20, 33" Background="Black"     Height="2"/>

        <Border Grid.Row="1" HorizontalAlignment="Left" Margin="3, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="2" HorizontalAlignment="Left" Margin="3, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="3" HorizontalAlignment="Left" Margin="3, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="4" HorizontalAlignment="Left" Margin="3, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />
        <Border Grid.Row="5" HorizontalAlignment="Left" Margin="3, 3, 0, 0" Background="#385D8A" Width="2" Height="17" />

        <Label Grid.Row="0" VerticalAlignment="Top"    Margin="3, 0, 0, 0" FontSize="17">계정등록</Label>
        <Label Grid.Row="1" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontSize="15">ID</Label>
        <Label Grid.Row="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontSize="15">이름</Label>
        <Label Grid.Row="3" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontSize="15">비밀번호</Label>
        <Label Grid.Row="4" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontSize="15">비밀번호 확인</Label>
        <Label Grid.Row="5" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontSize="15">사용 권한</Label>
        
        <Image Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
               Source="./Images/checked.png" Name="imgValidID"/>
        <TextBox Name="txtID"   
                 Grid.Row="1" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <Button Name="btnCheckID" Grid.Row="1" Grid.Column="3" Margin="5">중복확인</Button>
        <TextBox Name="txtName" 
                 Grid.Row="2" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <PasswordBox Name="txtNewPassword" 
                 Grid.Row="3" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <PasswordBox Name="txtCheckNewPassword" 
                 Grid.Row="4" Grid.Column="1" Margin="5" VerticalContentAlignment="Center" MaxLength="12"/>
        <ComboBox Name="cmbAuthority" 
                 Grid.Row="5" Grid.Column="1" Margin="5" VerticalContentAlignment="Center"/>
        <StackPanel Grid.Row="7" Grid.ColumnSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <Button Name="btnOK" Height="35" Width="100" Margin="10, 0">확 인</Button>
            <Button Name="btnCancel"  Height="35" Width="100" Margin="10, 0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
