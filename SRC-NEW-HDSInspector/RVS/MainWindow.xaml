<Window x:Class="RVS.MainWindow"
        xmlns:my="clr-namespace:Common;assembly=Common" 
        xmlns:local="clr-namespace:RVS"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"        
        mc:Ignorable="d"
        WindowState="Maximized"
        Icon="Images/main_icon.ico"
        Title="Haesung DS Verify SW v1.0.2 [2017.06.28]" Height="1030" Width="1920" WindowStartupLocation="CenterScreen">
    <Grid Background="Silver">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="290"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="310"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1200"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid Grid.Column="1"  Margin="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="105"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="53"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="54"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="54"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Silver" BorderThickness="2,2,1,2" CornerRadius="5" Margin="0" BorderBrush="Gray" />
                <Border Grid.Column="1" Background="#FFF6EEEE" BorderThickness="2,2,1,2" CornerRadius="5,0,0,5" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="2" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="3" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="4" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="5" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="6" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="7" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="8" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="9" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="10" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="11" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="12" Background="WhiteSmoke" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="13" Background="#FFF6EEEE" BorderThickness="1,2,1,2" Margin="0" BorderBrush="#FFFFCD71" />
                <Border Grid.Column="14" Background="WhiteSmoke" BorderThickness="1,2,2,2" CornerRadius="0,5,5,0" Margin="0" BorderBrush="#FFFFCD71" />
                <Label Grid.Column="1" Margin="0,5,0,5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="16" FontWeight="Bold">모델명</Label>
                <Label Grid.Column="3" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="16" FontWeight="Bold">Lot</Label>
                <Label Grid.Column="5" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="15" FontWeight="Bold">Verify전수율</Label>
                <Label Grid.Column="7" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="15" FontWeight="Bold">Verify후수율</Label>
                <Label Grid.Column="9" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="13" FontWeight="Bold">StripID</Label>
                <Label Grid.Column="11" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="13" FontWeight="Bold">UnitX</Label>
                <Label Grid.Column="13" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="13" FontWeight="Bold">UnitY</Label>

                <Label Name="lblMC" Grid.Column="0" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="20" FontWeight="Bold">CAI04</Label>
                <Label Name="lblModel" Grid.Column="2" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="20" FontWeight="Bold">000</Label>
                <Label Name="lblLot" Grid.Column="4" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="20" FontWeight="Bold">123456789-0</Label>
                <Label Name="lblBYield" Grid.Column="6" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="20" FontWeight="Bold" Foreground="Red">87.4</Label>
                <Label Name="lblAYield" Grid.Column="8" Margin="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="20" FontWeight="Bold" Foreground="#FF0032FF"></Label>
                

                <Label Name="lblStripID" Grid.Column="10" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="15" FontWeight="Bold">000</Label>
                <Label Name="lblUnitX" Grid.Column="12" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="15" FontWeight="Bold">03</Label>
                <Label Name="lblUnitY" Grid.Column="14" Margin="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontFamily="Arial" FontSize="15" FontWeight="Bold">05</Label>
            </Grid>
            <local:StripMap Grid.Row="1" x:Name="Stripmap" Margin="3"></local:StripMap>
        </Grid>
        
        <local:ListImage Grid.Row="2" x:Name="imgList"></local:ListImage>
        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="3" Margin="5,5" >
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1, 1, 1, 1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="3" Direction="310" Color="Black" BlurRadius="4" Opacity="0.5"/>
                </Border.Effect>
                <Rectangle>
                    <Rectangle.Fill>
                        <ImageBrush ImageSource ="/RVS;component/Images/DEF.png" Opacity="0.5"/>
                    </Rectangle.Fill>
                </Rectangle>
            </Border>
            <my:AntiAliasedImage Name="WideImage" Grid.Row="1" Stretch="Fill" />
        </Grid>
        <Grid Grid.Row="4" Grid.ColumnSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="5"/>
                <RowDefinition/>
                <RowDefinition Height="5"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1500"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Image Grid.RowSpan="5" Source ="/RVS;component/Images/inspector.jpg" Opacity="0.5"></Image>
            <local:StatusCtrl x:Name="Status1" Grid.Row="0"></local:StatusCtrl>
            <local:StatusCtrl x:Name="Status2" Grid.Row="2"></local:StatusCtrl>
            <local:StatusCtrl x:Name="Status3" Grid.Row="4" Visibility="Hidden"></local:StatusCtrl>
            <Grid Grid.Column="1" Grid.RowSpan="2" Name="grdButton">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Name="btnPad0" Grid.Column="0" Grid.Row="5" Margin="2,0" FontSize="17" FontWeight="Bold" Tag="0">양품(_0)</Button>
                <Button Name="btnPad1" Grid.Column="1" Grid.Row="5" Margin="2,0" FontSize="17" FontWeight="Bold" Tag="1">불량(_1)</Button>
                <Button Name="btnPad3" Grid.Column="2" Grid.Row="5" Margin="2,0" FontSize="17" FontWeight="Bold" Tag="3">이전(_3)</Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
