<Window x:Class="Common.Control.InputNumberBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" ResizeMode="NoResize" WindowStyle="ToolWindow" Icon="{x:Null}"
             WindowStartupLocation="CenterOwner"
             Height="210" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="30"/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <Border.Background>
                <RadialGradientBrush Center="0.179,0.011" GradientOrigin="0.179,0.011" RadiusY="0.876">
                    <GradientStop Color="#FFF3BC44"/>
                    <GradientStop Color="#FFE49119" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
            <TextBlock FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial"
                   TextWrapping="Wrap" Name="txtCaption">선택한 영역의 Unit 행 번호를 지정 바랍니다.</TextBlock>
        </Border>

        <TextBlock Grid.Row="1" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial"
                   TextWrapping="Wrap" Name="txtHelp">모델스펙 기준 최대값 X 입니다.</TextBlock>

        <toolkit:IntegerUpDown Name="txtUnitNumber" Grid.Row="2" Width="80" Height="30" Value="1" FontSize="13" Increment="1" Maximum="100" Minimum="1"/>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 5, 0, 10">
            <Button Width="100" Height="30" Name="btnOK">확 인</Button>
            <Button Width="100" Height="30" Name="btnCancel" Margin="10, 0, 0, 0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
