<Window x:Class="Common.Control.WarningMessageBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             WindowStartupLocation="CenterOwner"
             Title="Warning Message" Height="220" Width="350" ResizeMode="NoResize" WindowStyle="ToolWindow" Icon="{x:Null}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="2" Background="#AAEEEEEE"/>
        <Image Source="./Images/warning.png" Margin="25"/>
        <TextBlock x:Name="txtMessage" Grid.Column="1" TextWrapping="Wrap" Margin="0, 10, 10, 10" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Width="100" Height="30" Name="btnOK">확 인</Button>
            <Button Width="100" Height="30" Name="btnCancel" Margin="10, 0, 0, 0">취 소</Button>
        </StackPanel>
    </Grid>
</Window>
