<UserControl x:Class="Common.Control.RoundRectProgressBarUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Height="40" Width="40">
    <UserControl.Resources>
        <Style x:Key="canvasStyle" TargetType="{x:Type Canvas}">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style x:Key ="rectangle" 
                     TargetType="{x:Type Rectangle}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="LightBlue"/>
            <Setter Property="Canvas.Left" Value="8"/>
            <Setter Property="Canvas.Top" Value="8"/>
            <Setter Property="RadiusX" Value="20"/>
            <Setter Property="RadiusY" Value="20"/>
        </Style>
    </UserControl.Resources>

    <Canvas RenderTransformOrigin="0.5,0.5" 
             Style="{StaticResource canvasStyle}">        
        <Canvas Name="rotationCanvas" 
               RenderTransformOrigin="0.5,0.5" 
               Style="{StaticResource canvasStyle}">
            <Rectangle  Style="{StaticResource rectangle}">
            </Rectangle>            
            <Rectangle Opacity="0.9" 
                    Style="{StaticResource rectangle}">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="60" 
                           CenterX="13" CenterY="13"/>
                </Rectangle.RenderTransform>
            </Rectangle>            
            <Rectangle Opacity="0.7" 
                   Style="{StaticResource rectangle}">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="120" 
                         CenterX="13" CenterY="13"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Opacity="0.5" 
                      Style="{StaticResource rectangle}" >
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="180" 
                          CenterX="13" CenterY="13"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Opacity="0.25" 
                      Style="{StaticResource rectangle}" >
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="240" 
                      CenterX="13" CenterY="13"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Rectangle Opacity="0.1" 
                 Style="{StaticResource rectangle}" >
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="300" 
                      CenterX="13" CenterY="13"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Canvas.RenderTransform>
                <RotateTransform x:Name="SpinnerRotate"  
                   Angle="0" CenterX="21"
                   CenterY="21"/>
            </Canvas.RenderTransform>
        </Canvas>
    </Canvas>
</UserControl>