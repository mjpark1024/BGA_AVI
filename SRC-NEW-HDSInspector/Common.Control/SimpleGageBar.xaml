<UserControl x:Class="Common.Control.SimpleGageBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="300">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0">
            <Border BorderBrush="Gray" BorderThickness="3" CornerRadius="3" />
        </Border>
        <Grid Margin="6,4,6,4" Name="GagePanel" HorizontalAlignment="Stretch"/>
        <TextBlock Name="txtLabel" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial" FontWeight="Bold" FontSize="12" Foreground="DarkGray" Opacity="0.9"/>
        <TextBlock Grid.Column="1" Foreground="Black" Name="txtGage" FontSize="12" FontWeight="Bold" Margin="0,0,0,2"  HorizontalAlignment="Center" VerticalAlignment="Bottom" FontFamily="Arial" Opacity="0.9">90%</TextBlock>
    </Grid>
</UserControl>
