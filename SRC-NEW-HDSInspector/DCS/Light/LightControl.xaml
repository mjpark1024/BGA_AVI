<UserControl x:Class="DCS.LightControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:Common;assembly=Common"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500">
    <UserControl.Resources>
        <!--common:DoubleToIntegerConverter x:Key="doubleToIntConverter" m_nMax="100" m_nMin="0"/-->

        <Style x:Key="SlidingToggleButton2" TargetType="{x:Type ToggleButton}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <ControlTemplate.Resources>
                            <Storyboard x:Key="ToggleOn">
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="(FrameworkElement.Margin)" Storyboard.TargetName="SlidingBorder">
                                    <EasingThicknessKeyFrame KeyTime="0:0:0.1" Value="15,0,0,0"/>
                                    <EasingThicknessKeyFrame KeyTime="0:0:0.15" Value="22,0,0,0"/>
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                            <Storyboard x:Key="ToggleOff">
                                <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="(FrameworkElement.Margin)" Storyboard.TargetName="SlidingBorder">
                                    <EasingThicknessKeyFrame KeyTime="0:0:0.1" Value="0"/>
                                </ThicknessAnimationUsingKeyFrames>
                            </Storyboard>
                        </ControlTemplate.Resources>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="4" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            <Grid Grid.Column="1" Width="Auto" Background="{x:Null}">
                                <Border BorderBrush="#FF9DA2A4" BorderThickness="1" CornerRadius="1">
                                    <Border.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                            <GradientStop Color="White" Offset="1"/>
                                            <GradientStop Color="#FF858688"/>
                                            <GradientStop Color="#FFDBDCDD" Offset="0.112"/>
                                            <GradientStop Color="#FFAAABAD" Offset="0.04"/>
                                            <GradientStop Color="#FFCACBCC" Offset="0.08"/>
                                            <GradientStop Color="#FFFEFEFE" Offset="0.149"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Text="%" d:LayoutOverrides="Width, Height" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,7,0"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Text="값" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0"/>
                                <Border x:Name="SlidingBorder" BorderBrush="Black" BorderThickness="1" Width="22" HorizontalAlignment="Left" CornerRadius="2" Background="{TemplateBinding Background}">
                                    <Border BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="#7FFFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </Grid>
                            <Border x:Name="DisabledBorder" BorderBrush="{x:Null}" BorderThickness="1" Grid.ColumnSpan="2" CornerRadius="1" Background="White" Opacity="0" IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="true"/>
                            <Trigger Property="IsChecked" Value="true">
                                <Trigger.ExitActions>
                                    <BeginStoryboard x:Name="ToggleOff_BeginStoryboard" Storyboard="{StaticResource ToggleOff}"/>
                                </Trigger.ExitActions>
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource ToggleOn}"/>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#ADADAD"/>
                                <Setter Property="Opacity" TargetName="DisabledBorder" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#FF2F63FF"/>
        </Style>
    </UserControl.Resources>
    <Grid Height="Auto" Width="Auto">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="75"/>
            <ColumnDefinition Width="250*"/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>
        <Label Content="동축1" Name="lblLight1" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="0" Margin="2, 0, 0, 0"/>
        <Label Content="동축2" Name="lblLight2" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="1" Margin="2, 0, 0, 0"/>
        <Label Content="측광상1" Name="lblLight3" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="2" Margin="2, 0, 0, 0"/>
        <Label Content="측광상2" Name="lblLight4" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="3" Margin="2, 0, 0, 0"/>
        <Label Content="측광하1" Name="lblLight5" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="4" Margin="2, 0, 0, 0"/>
        <Label Content="측광하2" Name="lblLight6" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="5" Margin="2, 0, 0, 0"/>
        <Label Content="측광하2" Name="lblLight7" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="6" Margin="2, 0, 0, 0"/>
        <Label Content="측광하2" Name="lblLight8" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontWeight="Normal" FontSize="11" Grid.Row="7" Margin="2, 0, 0, 0"/>

        <Slider Name="sldrLight1" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="0" Delay="100" SmallChange="1" LargeChange="5" Tag="1" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight2" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="1" Delay="100" SmallChange="1" LargeChange="5" Tag="2" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight3" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="2" Delay="100" SmallChange="1" LargeChange="5" Tag="3" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight4" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="3" Delay="100" SmallChange="1" LargeChange="5" Tag="4" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight5" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="4" Delay="100" SmallChange="1" LargeChange="5" Tag="5" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight6" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="5" Delay="100" SmallChange="1" LargeChange="5" Tag="6" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight7" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="6" Delay="100" SmallChange="1" LargeChange="5" Tag="7" ValueChanged="sldLight_ValueChanged"/>
        <Slider Name="sldrLight8" Grid.Column="1" HorizontalAlignment="Stretch" Interval="1" Maximum="80" Minimum="0" Orientation="Horizontal" TickFrequency="10" TickPlacement="Both" Value="0" Grid.Row="7" Delay="100" SmallChange="1" LargeChange="5" Tag="8" ValueChanged="sldLight_ValueChanged"/>

        <toolkit:IntegerUpDown Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight1" Text="{Binding ElementName=sldrLight1, Path=Value, Mode=OneWay}" Margin="2" Tag="1" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="1" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight2" Text="{Binding ElementName=sldrLight2, Path=Value, Mode=OneWay}" Margin="2" Tag="2" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="2" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight3" Text="{Binding ElementName=sldrLight3, Path=Value, Mode=OneWay}" Margin="2" Tag="3" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="3" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight4" Text="{Binding ElementName=sldrLight4, Path=Value, Mode=OneWay}" Margin="2" Tag="4" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="4" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight5" Text="{Binding ElementName=sldrLight5, Path=Value, Mode=OneWay}" Margin="2" Tag="5" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="5" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight6" Text="{Binding ElementName=sldrLight6, Path=Value, Mode=OneWay}" Margin="2" Tag="6" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="6" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight7" Text="{Binding ElementName=sldrLight7, Path=Value, Mode=OneWay}" Margin="2" Tag="7" FontSize="12"/>
        <toolkit:IntegerUpDown Grid.Row="7" Grid.Column="2" Minimum="0" Maximum="80" 
                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                              Name="txtLight8" Text="{Binding ElementName=sldrLight8, Path=Value, Mode=OneWay}" Margin="2" Tag="8" FontSize="12"/>

        <StackPanel Orientation="Horizontal" Grid.Row="10" Grid.ColumnSpan="3" HorizontalAlignment="Center">
            <Rectangle Width="20"/>
        </StackPanel>
    </Grid>
</UserControl>