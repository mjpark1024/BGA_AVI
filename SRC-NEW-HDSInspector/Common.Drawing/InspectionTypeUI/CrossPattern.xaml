<UserControl x:Class="Common.Drawing.InspectionTypeUI.CrossPattern"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
            xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="300" Width="300">
    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="5">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">인식키 검사</TextBlock>
        </Border>

        <!-- Lower threshold, Upper threshold -->
        <TextBlock FontSize="11.5" Grid.Row="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">하한 임계(GV)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtLowerThreshold"
                              Grid.Row="1" Grid.Column="1">100</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="2"  VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">상한 임계</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtUpperThreshold"
                              Grid.Row="1" Grid.Column="3" Visibility="Hidden">200</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">공간편차 최소 허용범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinNormalRatio"
                              Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Hidden">50</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">공간편차 최대 허용범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMaxNormalRatio"
                              Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Hidden">50</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">PSR Shift 사용</TextBlock>
        <CheckBox Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Name="chkPSRShift"></CheckBox>

        <TextBlock FontSize="11.5" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">BA면 알고리즘 적용</TextBlock>
        <CheckBox Grid.Column="4" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Name="chkPSRShiftBA"></CheckBox>

        <TextBlock FontSize="13" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5, 0, 0, 0">PSR MarginX(um)</TextBlock>
        <TextBlock Name="lblPSRMarginX" FontSize="13" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5, 0, 0, 0" FontWeight="Bold">25</TextBlock>
        <TextBlock FontSize="13" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="5, 0, 0, 0">PSR MarginY(um)</TextBlock>
        <TextBlock Name="lblPSRMarginY" FontSize="13" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5, 0, 0, 0" FontWeight="Bold">25</TextBlock>


        <TextBlock FontSize="11.5" Grid.Row="5" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">인식키 불량 검출</TextBlock>
        <CheckBox Grid.Column="1" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Center" Name="chkInspect"></CheckBox>

        <TextBlock FontSize="11.5" Grid.Row="6" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">두께(px)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinHeightSize"
                              Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2">3</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="7" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">Open Size(px)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinDefectSize"
                              Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2">30</common:NumberTextBox>

    </Grid>
</UserControl>