<UserControl x:Class="Common.Drawing.InspectionTypeUI.PSROdd"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Common.Drawing.InspectionTypeUI"
             xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="300">

    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="4">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">PSR이물 검사</TextBlock>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden" Grid.Row="1" Background="White">
            <Grid Grid.Row="1" Background="LightGray">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="11.5" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" FontWeight="Bold">■ 검사 유형  설정 ■</TextBlock>
                
                <RadioButton Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="3, 0, 0, 0"
                         Name="rad_Non_Circuit" IsChecked="True" Tag="0" >비 회로부</RadioButton>
                <RadioButton Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="3, 0, 0, 0"
                         Name="radCircuit" IsChecked ="False" Tag="1">회로부</RadioButton>



                <Grid x:Name="grd_Non_CircuitParam" Grid.Row="3" Grid.ColumnSpan="4" Grid.RowSpan="19" Visibility="Visible">
                    
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                    
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                        <!--Core(RGB)-->
                        <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5, 0, 0, 0">● Core(RGB)</TextBlock>
                    
                        <TextBlock FontSize="11.5" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">임계값</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="2" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                           MinValue="1" MaxValue="255" Round="0" Name="txt_Core_Threshold">125</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">예외처리 임계</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="3" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                           MinValue="1" MaxValue="255" Round="0" Name="txt_Core_ExceptionThreshold">20</common:NumberTextBox>

                        <TextBlock FontSize="11" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" VerticalAlignment="Center" Margin="5, 0, 0, 0">
                            (수식 : RGB합산GV + 임계값 + Margin > 255)
                        </TextBlock>

                        <TextBlock FontSize="11.5" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">최소 검출사이즈 (px)</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="5" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                              MinValue="1" MaxValue="9999" Round="0" Name="txt_Core_MinDefectSize">100</common:NumberTextBox>


                        <!--Metal(채도)-->
                        <TextBlock FontSize="11.5" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5, 0, 0, 0">● Metal(채도)</TextBlock>
                    
                        <TextBlock FontSize="11.5" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">하한 임계</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="8" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                           MinValue="1" MaxValue="255" Round="0" Name="txt_Metal_LowerThreshold">40</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">상한 임계</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="9" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                           MinValue="1" MaxValue="255" Round="0" Name="txt_Metal_UpperThreshold">50</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">최소 검출사이즈 (px)</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="10" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                               MinValue="1" MaxValue="9999" Round="0" Name="txtMetal_MinDefectSize">150</common:NumberTextBox>

                    
                         <!--공통-->
                        <TextBlock FontSize="11.5" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5, 0, 0, 0">● 공통</TextBlock>


                        <TextBlock FontSize="11.5" Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">합산 범위 (px)</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="13" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                              MinValue="0" MaxValue="90000" Round="0" Name="txt_Summation_range">30</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">합산 검출사이즈 (px)</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="14" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                            MinValue="0" MaxValue="90000" Round="0" Name="txt_Summation_detection_size">200</common:NumberTextBox>


                        <TextBlock FontSize="11.5" Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">Mask 임계</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="15" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                              MinValue="0" MaxValue="255" Round="0" Name="txtMask_Threshold">100</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">Mask 확장</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="16" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                              MinValue="0" MaxValue="255" Round="0" Name="txtMask_Extension">2</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="17" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">단차 임계</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="17" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                    MinValue="0" MaxValue="255" Round="0" Name="txtStep_Threshold">40</common:NumberTextBox>

                        <TextBlock FontSize="11.5" Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">단차 확장</TextBlock>
                        <common:NumberTextBox Grid.Column="2" Grid.Row="18" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                        MinValue="0" MaxValue="255" Round="0" Name="txtStep_Expansion">2</common:NumberTextBox>

                        <!--필터-->
                        <TextBlock FontSize="11.5" Grid.Row="20" Grid.Column="0" Grid.ColumnSpan="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5, 0, 0, 0">● 필터</TextBlock>

                        <TextBlock FontSize="11.5" Grid.Row="21" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">길이 비율</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="21" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                        MinValue="0" MaxValue="9999" Round="0" Name="txtHV_ratio_value">5</common:NumberTextBox>
                        <TextBlock FontSize="11.5" Grid.Row="21" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">(초과)</TextBlock>


                        <TextBlock FontSize="11.5" Grid.Row="22" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">면적 비율</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="22" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                        MinValue="0" MaxValue="9999" Round="0" Name="txtMinRelative_size">5</common:NumberTextBox>
                        <TextBlock FontSize="11.5" Grid.Row="22" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">(미만)</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="23" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                        MinValue="0" MaxValue="9999" Round="0" Name="txtMaxRelative_size">4</common:NumberTextBox>
                        <TextBlock FontSize="11.5" Grid.Row="23" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">(초과)</TextBlock>

                    <TextBlock FontSize="11.5" Grid.Row="24" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">면적 비율(미만) 기준</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="24" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                                        MinValue="0" MaxValue="9999" Round="0" Name="txtArea_Relative">255</common:NumberTextBox>
                    <TextBlock FontSize="11.5" Grid.Row="24" Grid.Column="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">(pixel)</TextBlock>

                </Grid>

                <Grid x:Name="grd_Circuit_Param" Grid.ColumnSpan="4" Grid.Row="3" Grid.RowSpan="7" Visibility="Hidden">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="25"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">임계값</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="1" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                            MinValue="1" MaxValue="255" Round="0" Name="txtCircuit_Threshold">30</common:NumberTextBox>

                    <TextBlock FontSize="11.5" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">최소 검출사이즈 (px)</TextBlock>
                    <common:NumberTextBox Grid.Column="2" Grid.Row="2" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                            MinValue="1" MaxValue="9999" Round="0" Name="txtCircuit_MinDefectSize">200</common:NumberTextBox>
                </Grid>

          
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
