<UserControl x:Class="Common.Drawing.InspectionTypeUI.LeadShapeWithCenterLine"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="300" Width="300">
    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="40"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="5">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">Lead Shape With Center Line</TextBlock>
        </Border>

        <!-- Lower threshold, Upper threshold -->
        <TextBlock FontSize="11.5" Grid.Row="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">하한 임계</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtLowerThreshold"
                              Grid.Row="1" Grid.Column="1">100</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="2"  VerticalAlignment="Center" Margin="5, 0, 0, 0">상한 임계</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtUpperThreshold"
                              Grid.Row="1" Grid.Column="3">200</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">리드편차 최소 허용범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinNormalRatio"
                              Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Hidden">50</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="3" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">리드편차 최대 허용범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMaxNormalRatio"
                              Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Hidden">50</common:NumberTextBox>
        <Grid Grid.Row="9" Grid.ColumnSpan="5" Name="grdProject">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="11.5" Grid.Row="3" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">돌출 불량(GV)</TextBlock>
            <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtThreshProject"
                              Grid.Row="3" Grid.Column="1" >100</common:NumberTextBox>

            <TextBlock FontSize="11.5" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">돌출 크기(px)</TextBlock>
            <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtProjectSize"
                              Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="1">3</common:NumberTextBox>
            
        </Grid>
        <TextBlock FontSize="11.5" Grid.Row="10" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">Tip 삭제 픽셀 수(px)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="10" Round="0" Name="txtTipSize"
                              Grid.Row="10" Grid.Column="2" Grid.ColumnSpan="2">5</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="4" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">연속 불량 개수</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinHeightSize"
                              Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2">3</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="5" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 최소 선폭범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinWidthRatio"
                              Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2">30</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="6" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0" Visibility="Hidden">리드 최대 선폭범위 (%)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMaxWidthRatio"
                              Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Hidden">30</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="7" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 최소 선폭 (px)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinWidthSize"
                              Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2">5</common:NumberTextBox>

        <TextBlock FontSize="11.5" Grid.Row="8" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 최대 선폭 (px)</TextBlock>
        <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="5, 2, 2, 2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMaxWidthSize"
                              Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="2">30</common:NumberTextBox>
    </Grid>
</UserControl>