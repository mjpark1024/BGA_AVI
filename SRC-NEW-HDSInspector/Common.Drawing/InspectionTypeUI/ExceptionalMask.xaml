<UserControl x:Class="Common.Drawing.InspectionTypeUI.ExceptionalMask"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="3">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">Exeptional Mask</TextBlock>
        </Border>

        <TextBlock FontSize="11.5" Grid.Row="1" VerticalAlignment="Center" Margin="5, 0">Exception Row</TextBlock>
        <ComboBox Grid.Row="1" Grid.Column="1" Name="cbExceptionX" Margin ="1"/>

        <TextBlock FontSize="11.5" Grid.Row="2" VerticalAlignment="Center" Margin="5, 0">Exception Column</TextBlock>
        <ComboBox Grid.Row="2" Grid.Column="1" Name="cbExceptionY" Margin ="1"/>

        <TextBlock FontSize="11.5" Grid.Row="3" VerticalAlignment="Center" Margin="5, 0">연동 Offset</TextBlock>
        <ComboBox Grid.Row="3" Grid.Column="1" Name="cbUseOffset" Margin ="1"/>

    </Grid>
</UserControl>
