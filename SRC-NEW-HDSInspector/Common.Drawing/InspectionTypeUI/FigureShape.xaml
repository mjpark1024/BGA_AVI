<UserControl x:Class="Common.Drawing.InspectionTypeUI.FigureShape"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="400" Width="300">

    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="4">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">특이 형상 Half Etching 검사</TextBlock>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden" Grid.Row="1" Background="White">
            <Grid Grid.Row="1" Background="LightGray">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="11.5" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">평균값 최소범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtAverMinMargin"
                              Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">평균값 최대범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtAverMaxMargin"
                              Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2">20</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사조건 범위</TextBlock>
                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Name="chkMinRange" Margin="5, 0, 15, 0" IsChecked="True">Min</CheckBox>
                    <CheckBox Name="chkMaxRange" Margin="15, 0, 15, 0">Max</CheckBox>
                    <CheckBox Name="chkInRange"  Margin="15, 0, 5, 0">In</CheckBox>
                </StackPanel>

                <TextBlock FontSize="11.5" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사 최소 허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinMargin"
                              Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사 최대 허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMaxMargin"
                              Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 축소</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtErosionTrainIter"
                              Grid.Row="5" Grid.Column="1">1</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 확장</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtDilationTrainIter"
                              Grid.Row="5" Grid.Column="3">0</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">결과 축소</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtErosionInspIter"
                              Grid.Row="6" Grid.Column="1">0</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">결과 확장</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtDilationInspIter"
                              Grid.Row="6" Grid.Column="3">0</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 최소선폭 허용범위(px)</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinWidthSize"
                              Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2">30</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">연속 불량 개수</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtMinHeightSize"
                              Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="2">5</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 편차 최소 허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="-1000" MaxValue="1000" Round="0" Name="txtMinNormalRatio"
                              Grid.Row="9" Grid.Column="2" Grid.ColumnSpan="2">-10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">리드 편차 최대 허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="-1000" MaxValue="1000" Round="0" Name="txtMaxNormalRatio"
                              Grid.Row="10" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">최대 이동 거리</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtAlignMaxDist"
                              Grid.Row="11" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">어두운 영역 크기</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtDarkAreaWidth"
                              Grid.Row="12" Grid.Column="2" Grid.ColumnSpan="2">5</common:NumberTextBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>