<UserControl x:Class="Common.Drawing.InspectionTypeUI.BallPattern"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:common="clr-namespace:Common;assembly=Common"
             xmlns:toolkit="clr-namespace:Microsoft.Windows.Controls;assembly=WPFToolkit.Extended"
             mc:Ignorable="d" 
             d:DesignHeight="460" Width="300">

    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Background="#144B92" Grid.ColumnSpan="4">
            <TextBlock VerticalAlignment="Center" Foreground="White" Name="txtCaption" Margin="5, 0">Ball 검사</TextBlock>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Hidden" Grid.Row="1" Background="White">
            <Grid Grid.Row="1" Background="LightGray">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.ColumnSpan="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <RadioButton Grid.Column="0" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5, 0, 0, 0"
                         Name="radThresholdUpper">임계 이상</RadioButton>
                    <RadioButton Grid.Column="1" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5, 0, 0, 0"
                         Name="radThresholdLower">임계 이하</RadioButton>
                    <RadioButton Grid.Column="2" FontSize="11.5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5, 0, 0, 0"
                         Name="radThresholdRange" IsChecked="True">임계 범위</RadioButton>
                </Grid>

                <!-- Lower threshold, Upper threshold -->
                <TextBlock FontSize="11.5" Grid.Row="1" VerticalAlignment="Center" Margin="5, 0, 0, 0" Name="txtGV">임계 값</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtThreshold"
                              Grid.Row="1" Grid.Column="1">100</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="1" VerticalAlignment="Center" Margin="5, 0, 0, 0" Name="txtLowerGV">하한 임계</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtLowerThreshold"
                              Grid.Row="1" Grid.Column="1">100</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="1" Grid.Column="2"  VerticalAlignment="Center" Margin="5, 0, 0, 0" Name="txtUpperGV">상한 임계</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtUpperThreshold"
                              Grid.Row="1" Grid.Column="3">200</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 하한임계</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtMaskLowerThresh"
                              Grid.Row="3" Grid.Column="1">100</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 상한임계</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="255" Round="0" Name="txtMaskUpperThresh"
                              Grid.Row="3" Grid.Column="3">200</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">평균값 적용</TextBlock>
                <CheckBox FontSize="11.5" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="2, 0, 0, 0" Name="chkApplyAverDiff" IsChecked="False"/>

                <TextBlock FontSize="11.5" Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">PSR Shift 적용</TextBlock>
                <CheckBox FontSize="11.5" Grid.Row="4" Grid.Column="3" VerticalAlignment="Center" Margin="2, 0, 0, 0" Name="chkPSRShift" IsChecked="False"/>

                <TextBlock FontSize="11.5" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">평균값 최소범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                                      IsEnabled="{Binding ElementName=chkApplyAverDiff, Path=IsChecked, Mode=OneWay}"
                                      MinValue="0" MaxValue="1000" Round="0" Name="txtAverMinMargin"
                                      Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2">30</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">평균값 최대범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                                      IsEnabled="{Binding ElementName=chkApplyAverDiff, Path=IsChecked, Mode=OneWay}"
                                      MinValue="0" MaxValue="1000" Round="0" Name="txtAverMaxMargin"
                                      Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2">30</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사조건 범위</TextBlock>
                <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Name="chkMinRange" IsEnabled="{Binding ElementName=radThresholdRange, Path=IsChecked, Mode=OneWay}" Margin="5, 0, 15, 0" IsChecked="True">Min</CheckBox>
                    <CheckBox Name="chkMaxRange" IsEnabled="{Binding ElementName=radThresholdRange, Path=IsChecked, Mode=OneWay}" Margin="15, 0, 15, 0" IsChecked="True">Max</CheckBox>
                    <CheckBox Name="chkInRange"  IsEnabled="false" Margin="15, 0, 5, 0" Visibility="Hidden">In</CheckBox>
                </StackPanel>

                <TextBlock FontSize="11.5" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사최소허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinMargin"
                              Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="1">10</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="8" Grid.Column="2" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">검사최대허용범위</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMaxMargin"
                              Grid.Row="8" Grid.Column="3" Grid.ColumnSpan="1">10</common:NumberTextBox>

                <!--<TextBlock FontSize="11.5" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="1" VerticalAlignment="Center" Margin="5, 0, 0, 0">내부 검사 사용</TextBlock>
                <CheckBox FontSize="11.5" Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" Margin="2, 0, 0, 0" Name="chkState" IsChecked="True"/>-->

                <TextBlock FontSize="11.5" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 축소</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtErosionTrainIter"
                              Grid.Row="10" Grid.Column="1">1</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="10" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">마스크 확장</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtDilationTrainIter"
                              Grid.Row="10" Grid.Column="3">0</common:NumberTextBox>

                <!--<TextBlock FontSize="11.5" Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">결과 축소</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtErosionInspIter"
                              Grid.Row="11" Grid.Column="1">0</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="11" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">결과 확장</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="100" Round="0" Name="txtDilationInspIter"
                              Grid.Row="11" Grid.Column="3">0</common:NumberTextBox>

                <TextBlock FontSize="11.5" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">최소 검출사이즈</TextBlock>
                <Grid Grid.Row="12" Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige">MIN</TextBlock>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige" Grid.Column="2">MAX</TextBlock>
                    <common:NumberTextBox Grid.Column="1" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="1000" Round="0" Name="txtMinDefectSize">30</common:NumberTextBox>
                    <common:NumberTextBox Grid.Column="3" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="1000" Round="0" Name="txtMaxDefectSize">30</common:NumberTextBox>
                </Grid>

                <TextBlock FontSize="11.5" Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">미세불량 최소 검출사이즈</TextBlock>
                <Grid Grid.Row="13" Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige">MIN</TextBlock>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige" Grid.Column="2">MAX</TextBlock>
                    <common:NumberTextBox Grid.Column="1" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="100" Round="0" Name="txtMinSmallDefectSize">0</common:NumberTextBox>
                    <common:NumberTextBox Grid.Column="3" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="100" Round="0" Name="txtMaxSmallDefectSize">0</common:NumberTextBox>
                </Grid>

                <TextBlock FontSize="11.5" Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">미세불량 최소 검출개수</TextBlock>
                <Grid Grid.Row="14" Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige">MIN</TextBlock>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige" Grid.Column="2">MAX</TextBlock>
                    <common:NumberTextBox Grid.Column="1" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="100" Round="0" Name="txtMinSmallDefectCount">0</common:NumberTextBox>
                    <common:NumberTextBox Grid.Column="3" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="100" Round="0" Name="txtMaxSmallDefectCount">0</common:NumberTextBox>
                </Grid>-->

                <TextBlock FontSize="11.5" Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">Ball 검색 사이즈 px)</TextBlock>
                <Grid Grid.Row="15" Grid.Column="2" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="33"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige">MIN</TextBlock>
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Beige" Grid.Column="2">Mgn</TextBlock>
                    <common:NumberTextBox Grid.Column="1" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="10000" Round="0" Name="txtMinHeightSize">0</common:NumberTextBox>
                    <common:NumberTextBox Grid.Column="3" FontSize="13" VerticalContentAlignment="Center" Margin="-1, 2, 2, 2"
                                          MinValue="0" MaxValue="10000" Round="0" Name="txtMaxHeightSize">0</common:NumberTextBox>
                </Grid>

                <TextBlock FontSize="11.5" Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5, 0, 0, 0">외곽 검출 사이즈</TextBlock>
                <common:NumberTextBox FontSize="13" VerticalContentAlignment="Center" Margin="2"
                              MinValue="0" MaxValue="1000" Round="0" Name="txtMinWidthSize"
                              Grid.Row="16" Grid.Column="2" Grid.ColumnSpan="2">10</common:NumberTextBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>